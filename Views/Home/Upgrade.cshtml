@{
    Layout = "_SimpleLayout";
}

@{
    ViewData["Title"] = "انتخاب اشتراک | رستورانیار دلاویتا";
}


 






<div class="subscription-page-wrapper">
    <!-- ذرات پس‌زمینه -->
    <div class="bg-particles">
        <div class="particle"></div>
        <div class="particle"></div>
        <div class="particle"></div>
        <div class="particle"></div>
        <div class="particle"></div>
        <div class="particle"></div>
        <div class="particle"></div>
        <div class="particle"></div>
    </div>

    <!-- هدر -->
    <header class="page-header">
        <div class="header-badge">✨ رستورانیار دلاویتا</div>
        <h1 class="header-title">انتخاب <span class="highlight">اشتراک</span> مناسب</h1>
        <p class="header-subtitle">
            اشتراک مورد نظر خود را با توجه به نیاز رستوران‌تان انتخاب کنید.
            <br>
            توجه کنید که <strong>اشتراک‌های رایگان، برنزی و نقره‌ای</strong> مخصوص اپلیکیشن موبایل هستند و به امکانات نسخه وب یا پنل مدیریتی دسترسی ندارند.
            <br>
              <strong>اشتراک طلایی</strong> شامل تمامی امکانات (اپلیکیشن + وب و پنل مدیریت) می‌باشد.
        </p>
    </header>

    <!-- انتخاب‌گر مدت اشتراک -->
    <div class="duration-selector-wrapper">
        <div class="duration-selector" id="durationSelector">
            <button class="duration-option active" data-duration="monthly" data-months="1">
                <span class="duration-label">۱ ماهه</span>
                <span class="duration-save"></span>
            </button>
            <button class="duration-option" data-duration="3monthly" data-months="3">
                <span class="duration-label">۳ ماهه</span>
             
            </button>
            <button class="duration-option" data-duration="6monthly" data-months="6">
                <span class="duration-label">۶ ماهه</span>
               
            </button>
        </div>
    </div>

    <!-- کارت‌های اشتراک -->
    <div class="pricing-grid" id="pricingGrid">
        <!-- کارت‌ها با جاوااسکریپت ساخته می‌شوند -->
        <div class="loading-state">
            <div class="loading-spinner"></div>
            <p>در حال بارگذاری اشتراک‌ها...</p>
        </div>
    </div>

    <!-- یادداشت پایین صفحه -->
    <!-- یادداشت پایین صفحه - طراحی مدرن -->
    <div class="page-footer-note">
        <div class="note-container">
             

            <div class="note-content-grid">
                <div class="note-description">
                    <p>
                        اشتراک خود را می‌توانید از طریق <strong>درگاه پرداخت در همین صفحه</strong>
                        یا از طریق <strong>اپلیکیشن اندرویدی رستورانیار دلاویتا</strong> (در کافه‌بازار)
                        فعال کنید.
                    </p>
                     

                    
                </div>

                <div class="activation-options">
                    <div class="option-card">
                        <div class="option-title">
                             
                            اپلیکیشن اندروید رستورانیار دلاویتا
                        </div>
                        <p class="option-description">
                            مناسب برای اشتراک‌های رایگان، برنزی و نقره‌ای
                        </p>
                        <a href="https://cafebazaar.ir/app/com.musiclrc.resturanyar"
                           class="option-button"
                           title="دریافت اپلیکیشن"
                           target="_blank"
                           rel="noopener noreferrer">
                            
                            دانلود از کافه‌بازار
                        </a>
                    </div>

                    
                </div>
            </div>

            <div class="note-disclaimer">
                <strong></strong> پس از پرداخت، اشتراک شما بلافاصله فعال شده و می‌توانید از تمامی امکانات آن استفاده کنید.
                در صورت بروز هرگونه مشکل با پشتیبانی تماس بگیرید.
            </div>
        </div>
    </div>
</div>

<style>
    :root {
        --brand-orange: #ff6f3c;
        --brand-orange-dark: #e85c2c;
        --brand-orange-light: #ff9a3c;
        --gold: #d4a853;
        --gold-light: #f0d78c;
        --gold-dark: #b8943a;
        --silver: #8a8a9a;
        --silver-light: #b8b8c8;
        --bronze: #c08552;
        --bronze-light: #dba87a;
        --free: #6b9e85;
        --free-light: #8cc4a8;
        --bg-warm: #fdf6f0;
        --card-bg: #ffffff;
        --text-dark: #2c2c2c;
        --text-medium: #555;
        --text-light: #777;
        --shadow-sm: 0 2px 8px rgba(0,0,0,0.06);
        --shadow-md: 0 8px 30px rgba(0,0,0,0.10);
        --shadow-lg: 0 20px 50px rgba(0,0,0,0.14);
        --shadow-gold: 0 12px 40px rgba(212,168,83,0.30);
        --radius-sm: 12px;
        --radius-md: 18px;
        --radius-lg: 24px;
        --transition: 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }

    * {
        box-sizing: border-box;
    }

    body {
        background: linear-gradient(160deg, #fdf3ea 0%, #fef9f4 25%, #fdf6f0 50%, #fefaf6 75%, #fdf3ea 100%);
        font-family: 'IRANYekan', 'Vazirmatn', 'IRANSans', sans-serif;
        margin: 0;
        padding: 0;
        direction: rtl;
        min-height: 100vh;
        overflow-x: hidden;
    }

    .subscription-page-wrapper {
        position: relative;
        max-width: 1300px;
        margin: 0 auto;
        padding: 30px 20px 50px;
        z-index: 1;
    }

    /* === ذرات پس‌زمینه === */
    .bg-particles {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        pointer-events: none;
        z-index: 0;
        overflow: hidden;
    }

    .particle {
        position: absolute;
        border-radius: 50%;
        background: var(--brand-orange);
        opacity: 0.04;
        animation: floatUp 14s infinite ease-in;
    }

        .particle:nth-child(1) {
            width: 80px;
            height: 80px;
            left: 5%;
            top: 70%;
            animation-delay: 0s;
            animation-duration: 16s;
            background: var(--brand-orange-light);
        }

        .particle:nth-child(2) {
            width: 50px;
            height: 50px;
            left: 15%;
            top: 50%;
            animation-delay: 2s;
            animation-duration: 13s;
        }

        .particle:nth-child(3) {
            width: 100px;
            height: 100px;
            left: 25%;
            top: 80%;
            animation-delay: 4s;
            animation-duration: 18s;
            background: var(--gold-light);
        }

        .particle:nth-child(4) {
            width: 35px;
            height: 35px;
            left: 40%;
            top: 60%;
            animation-delay: 1s;
            animation-duration: 11s;
        }

        .particle:nth-child(5) {
            width: 70px;
            height: 70px;
            left: 55%;
            top: 75%;
            animation-delay: 5s;
            animation-duration: 15s;
            background: var(--brand-orange-light);
        }

        .particle:nth-child(6) {
            width: 45px;
            height: 45px;
            left: 70%;
            top: 45%;
            animation-delay: 3s;
            animation-duration: 12s;
        }

        .particle:nth-child(7) {
            width: 90px;
            height: 90px;
            left: 80%;
            top: 65%;
            animation-delay: 6s;
            animation-duration: 17s;
            background: var(--gold-light);
            opacity: 0.03;
        }

        .particle:nth-child(8) {
            width: 55px;
            height: 55px;
            left: 90%;
            top: 55%;
            animation-delay: 0.5s;
            animation-duration: 14s;
        }

    @@keyframes floatUp {
        0% {
            transform: translateY(0) scale(1) rotate(0deg);
            opacity: 0.03;
        }

        25% {
            transform: translateY(-60px) scale(1.3) rotate(5deg);
            opacity: 0.06;
        }

        50% {
            transform: translateY(-120px) scale(1.1) rotate(-3deg);
            opacity: 0.04;
        }

        75% {
            transform: translateY(-40px) scale(1.4) rotate(2deg);
            opacity: 0.05;
        }

        100% {
            transform: translateY(0) scale(1) rotate(0deg);
            opacity: 0.03;
        }
    }

    /* === هدر === */
    .page-header {
        text-align: center;
        padding: 20px 0 10px;
        position: relative;
        z-index: 1;
    }

    .header-badge {
        display: inline-block;
        background: linear-gradient(135deg, var(--brand-orange), var(--brand-orange-light));
        color: #fff;
        padding: 8px 22px;
        border-radius: 30px;
        font-size: 14px;
        font-weight: bold;
        letter-spacing: 0.5px;
        margin-bottom: 16px;
        box-shadow: 0 4px 15px rgba(255,111,60,0.25);
    }

    .header-title {
        font-size: 38px;
        font-weight: 900;
        color: var(--text-dark);
        margin: 0 0 10px;
        line-height: 1.3;
    }

        .header-title .highlight {
            background: linear-gradient(135deg, var(--brand-orange), var(--gold-dark));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            position: relative;
        }

    .header-subtitle {
        font-size: 17px;
        color: var(--text-medium);
        max-width: 600px;
        margin: 0 auto;
        line-height: 1.8;
    }

    /* === انتخاب‌گر مدت === */
    .duration-selector-wrapper {
        display: flex;
        justify-content: center;
        margin: 30px 0 35px;
        position: relative;
        z-index: 1;
    }

    .duration-selector {
        display: flex;
        background: #fff;
        border-radius: 40px;
        padding: 6px;
        box-shadow: var(--shadow-sm);
        gap: 4px;
        border: 1.5px solid #f0e8df;
    }

    .duration-option {
        padding: 11px 28px;
        border: none;
        background: transparent;
        border-radius: 34px;
        cursor: pointer;
        font-size: 15px;
        font-weight: 600;
        color: var(--text-medium);
        transition: var(--transition);
        position: relative;
        white-space: nowrap;
        font-family: inherit;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 3px;
    }

        .duration-option.active {
            background: linear-gradient(135deg, var(--brand-orange), var(--brand-orange-dark));
            color: #fff;
            box-shadow: 0 4px 14px rgba(255,111,60,0.35);
        }

        .duration-option:hover:not(.active) {
            color: var(--brand-orange);
            background: #fff8f4;
        }

    .duration-save {
        font-size: 11px;
        font-weight: 500;
        opacity: 0;
        transition: var(--transition);
        height: 0;
        overflow: hidden;
    }

    .duration-option.active .duration-save {
        opacity: 1;
        height: auto;
    }

    .save-badge {
        color: #ffe0c0;
    }

    .save-badge-best {
        color: #ffd700;
        font-weight: 700;
    }

    /* === گرید کارت‌ها === */
    .pricing-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 22px;
        position: relative;
        z-index: 1;
        align-items: stretch;
    }

    @@media (max-width: 1200px) {
        .pricing-grid {
            grid-template-columns: repeat(2, 1fr);
            gap: 18px;
        }

        .header-title {
            font-size: 30px;
        }
    }

    @@media (max-width: 768px) {
        .pricing-grid {
            grid-template-columns: 1fr;
            max-width: 460px;
            margin: 0 auto;
        }

        .header-title {
            font-size: 26px;
        }

        .header-subtitle {
            font-size: 15px;
        }

        .duration-selector {
            flex-wrap: wrap;
            justify-content: center;
        }

        .duration-option {
            padding: 10px 18px;
            font-size: 13px;
        }
    }

    /* === کارت اشتراک === */
    .pricing-card {
        background: var(--card-bg);
        border-radius: var(--radius-lg);
        padding: 30px 24px 28px;
        position: relative;
        border: 2px solid transparent;
        box-shadow: var(--shadow-md);
        transition: all 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
        display: flex;
        flex-direction: column;
        overflow: hidden;
    }

        .pricing-card:hover {
            transform: translateY(-6px);
            box-shadow: var(--shadow-lg);
        }

        .pricing-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 4px;
        }

        /* کارت رایگان */
        .pricing-card.tier-free {
            border-color: #e8f0ec;
        }

            .pricing-card.tier-free::before {
                background: linear-gradient(90deg, var(--free-light), var(--free));
            }

            .pricing-card.tier-free:hover {
                border-color: var(--free-light);
            }

        /* کارت برنزی */
        .pricing-card.tier-bronze {
            border-color: #f0e4d8;
        }

            .pricing-card.tier-bronze::before {
                background: linear-gradient(90deg, var(--bronze-light), var(--bronze));
            }

            .pricing-card.tier-bronze:hover {
                border-color: var(--bronze-light);
            }

        /* کارت نقره‌ای */
        .pricing-card.tier-silver {
            border-color: #e4e4ee;
        }

            .pricing-card.tier-silver::before {
                background: linear-gradient(90deg, var(--silver-light), var(--silver));
            }

            .pricing-card.tier-silver:hover {
                border-color: var(--silver-light);
            }

        /* کارت طلایی */
        .pricing-card.tier-gold {
            border-color: var(--gold-light);
            box-shadow: var(--shadow-gold);
            z-index: 2;
        }

            .pricing-card.tier-gold::before {
                background: linear-gradient(90deg, #f0d78c, var(--gold), var(--gold-dark));
            }

            .pricing-card.tier-gold::after {
                content: '';
                position: absolute;
                top: -50%;
                left: -50%;
                width: 200%;
                height: 200%;
                background: radial-gradient(ellipse at 30% 20%, rgba(240,215,140,0.08) 0%, transparent 60%);
                pointer-events: none;
                animation: goldenShine 6s ease-in-out infinite;
            }

            .pricing-card.tier-gold:hover {
                transform: translateY(-8px);
                box-shadow: 0 18px 55px rgba(212,168,83,0.40);
                border-color: var(--gold);
            }

    @@keyframes goldenShine {
        0%, 100% {
            opacity: 0.5;
            transform: rotate(0deg);
        }

        50% {
            opacity: 1;
            transform: rotate(5deg);
        }
    }

    /* نشان محبوب‌ترین */
    .popular-badge {
        position: absolute;
        top: 18px;
        left: 20px;
        background: linear-gradient(135deg, #ff6f3c, #e85c2c);
        color: #fff;
        padding: 6px 16px;
        border-radius: 20px;
        font-size: 12px;
        font-weight: 700;
        letter-spacing: 0.5px;
        box-shadow: 0 3px 12px rgba(255,111,60,0.35);
        z-index: 3;
        animation: badgePulse 2.5s ease-in-out infinite;
    }

    @@keyframes badgePulse {
        0%, 100% {
            box-shadow: 0 3px 12px rgba(255,111,60,0.35);
        }

        50% {
            box-shadow: 0 6px 22px rgba(255,111,60,0.55);
        }
    }

    .popular-badge.gold-badge {
        background: linear-gradient(135deg, #d4a853, #b8943a);
        box-shadow: 0 3px 14px rgba(180,140,50,0.40);
    }

    /* محتوای کارت */
    .card-tier-icon {
        font-size: 42px;
        margin-bottom: 8px;
        display: block;
    }

    .card-tier-name {
        font-size: 22px;
        font-weight: 800;
        color: var(--text-dark);
        margin: 0 0 4px;
    }

    .card-tier-code {
        font-size: 11px;
        color: var(--text-light);
        letter-spacing: 1px;
        text-transform: uppercase;
        margin-bottom: 14px;
        display: block;
    }

    .card-description {
        font-size: 13px;
        color: var(--text-medium);
        line-height: 1.7;
        margin-bottom: 18px;
        min-height: 50px;
    }

    /* بخش قیمت */
    .card-pricing {
        margin-bottom: 18px;
        padding: 16px 0;
        border-top: 1px solid #f0ebe4;
        border-bottom: 1px solid #f0ebe4;
        text-align: center;
    }

    .price-original {
        font-size: 14px;
        color: #a69483;
        text-decoration: none;
        position: relative;
        display: inline-block; /* or block if needed */
        margin-bottom: 4px;
        opacity: 0.8;
    }

        .price-original::after {
            content: "";
            position: absolute;
            left: 0;
            right: 0;
            top: 50%;
            height: 2px;
            background: linear-gradient(to right, transparent, #d9534f, transparent);
            transform: rotate(-5deg);
        }

    .price-current {
        font-size: 36px;
        font-weight: 900;
        color: var(--text-dark);
        line-height: 1.2;
    }

    .tier-gold .price-current {
        background: linear-gradient(135deg, #b8943a, #8a6d2b);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
    }

    .price-unit {
        font-size: 14px;
        font-weight: 400;
        color: var(--text-medium);
        margin-right: 4px;
    }

    .price-free {
        font-size: 34px;
        font-weight: 900;
        color: var(--free);
    }

    .price-unavailable {
        font-size: 18px;
        color: #c0b8b0;
        font-weight: 600;
    }

    /* لیست ویژگی‌ها */
    .card-features {
        list-style: none;
        padding: 0;
        margin: 0 0 22px;
        flex-grow: 1;
    }

        .card-features li {
            padding: 7px 0;
            font-size: 13px;
            color: var(--text-medium);
            display: flex;
            align-items: center;
            gap: 10px;
            line-height: 1.5;
        }

    /* === Feature icon (modern) === */
    .feature-icon {
        width: 22px;
        height: 22px;
        border-radius: 999px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 12px;
        font-weight: 900;
        line-height: 1;
        /* glassy look */
        background: rgba(255,255,255,0.9);
        border: 1px solid rgba(0,0,0,0.06);
        box-shadow: 0 6px 16px rgba(0,0,0,0.06), inset 0 1px 0 rgba(255,255,255,0.9);
        /* prevents shrinking in flex rows */
        flex: 0 0 22px;
        /* subtle ring (looks premium) */
        outline: 3px solid rgba(255,111,60,0.08);
        outline-offset: 0px;
    }

        /* OK */
        .feature-icon.check {
            color: #ffffff;
            background: linear-gradient(135deg, #34d399, #16a34a);
            border-color: rgba(22,163,74,0.20);
            outline-color: rgba(22,163,74,0.12);
            box-shadow: 0 10px 24px rgba(22,163,74,0.18), inset 0 1px 0 rgba(255,255,255,0.35);
        }

        /* NO */
        .feature-icon.cross {
            color: #ffffff;
            background: linear-gradient(135deg, #fb7185, #e11d48);
            border-color: rgba(225,29,72,0.22);
            outline-color: rgba(225,29,72,0.12);
            box-shadow: 0 10px 24px rgba(225,29,72,0.16), inset 0 1px 0 rgba(255,255,255,0.30);
        }

        /* Neutral */
        .feature-icon.neutral {
            color: #ffffff;
            background: linear-gradient(135deg, #34d399, #16a34a);
            border-color: rgba(15,23,42,0.06);
            outline-color: rgba(15,23,42,0.05);
            box-shadow: 0 10px 24px rgba(15,23,42,0.06), inset 0 1px 0 rgba(255,255,255,0.9);
        }


    /* دکمه */
    .card-cta {
        display: block;
        width: 100%;
        padding: 13px 20px;
        border-radius: 30px;
        font-size: 15px;
        font-weight: 700;
        text-align: center;
        cursor: pointer;
        border: none;
        transition: var(--transition);
        text-decoration: none;
        font-family: inherit;
        letter-spacing: 0.3px;
    }

        .card-cta.cta-free {
            background: #e8f5e9;
            color: #2e7d32;
        }

            .card-cta.cta-free:hover {
                background: #c8e6c9;
                box-shadow: 0 4px 14px rgba(46,125,50,0.20);
            }

        .card-cta.cta-bronze {
            background: linear-gradient(135deg, var(--bronze), var(--bronze-light));
            color: #fff;
        }

            .card-cta.cta-bronze:hover {
                box-shadow: 0 6px 20px rgba(192,133,82,0.35);
                transform: translateY(-2px);
            }

        .card-cta.cta-silver {
            background: linear-gradient(135deg, #7a7a8e, #9a9ab0);
            color: #fff;
        }

            .card-cta.cta-silver:hover {
                box-shadow: 0 6px 20px rgba(138,138,154,0.35);
                transform: translateY(-2px);
            }

        .card-cta.cta-gold {
            background: linear-gradient(135deg, #d4a853, #c49a3c, #b8892e);
            color: #fff;
            font-size: 16px;
            padding: 15px 20px;
            box-shadow: 0 6px 22px rgba(200,155,50,0.35);
        }

            .card-cta.cta-gold:hover {
                box-shadow: 0 10px 30px rgba(200,155,50,0.50);
                transform: translateY(-3px);
            }

        .card-cta .cta-subtext {
            display: block;
            font-size: 10px;
            font-weight: 400;
            opacity: 0.85;
            margin-top: 2px;
        }

    /* === لودینگ === */
    .loading-state {
        grid-column: 1 / -1;
        text-align: center;
        padding: 70px 20px;
        color: var(--text-medium);
    }

    .loading-spinner {
        width: 44px;
        height: 44px;
        border: 4px solid #f0e8df;
        border-top-color: var(--brand-orange);
