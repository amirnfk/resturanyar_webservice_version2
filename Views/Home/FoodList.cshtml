@model List<FoodItemViewModel>
@{
    var restaurantName = ViewBag.RestaurantName as string;
    ViewData["Title"] = "لیست آیتم ها - " + @restaurantName;


   
    var placeholder = Url.Content("~/images/food_placeholder.jpg");
}

<link href="~/css/bootstrap_rtl_min.css" rel="stylesheet" />

<style>
    /* Scoped to this page */
    .food-page {
        direction: rtl;
        font-family: "IRANYekan","IRANSans",system-ui,-apple-system,Segoe UI,Roboto,sans-serif;
    }

    /* Toolbar */
    .food-toolbar {
        background: #fff;
        border: 1px solid #e9eef5;
        border-radius: 14px;
        box-shadow: 0 8px 28px rgba(15, 23, 42, 0.06);
        padding: 10px;
    }

        .food-toolbar .form-control, .food-toolbar .form-select {
            border-radius: 10px;
            border-color: #e6eaf0;
        }

    .btn-primary {
        --bs-btn-bg: #ff7a00;
        --bs-btn-border-color: #ff7a00;
        --bs-btn-hover-bg: #f06700;
        --bs-btn-hover-border-color: #f06700;
        border-radius: 10px;
        padding: .5rem .9rem;
        font-weight: 700;
        box-shadow: 0 8px 20px rgba(255,122,0,.22);
        transition: transform .12s ease;
    }

        .btn-primary:hover {
            transform: translateY(-1px);
        }

    /* Card */
    .food-card {
        position: relative;
        border: 1px solid #eef1f6;
        border-radius: 12px;
        overflow: hidden;
        background: #fff;
        box-shadow: 0 10px 24px rgba(15, 23, 42, .06);
        transition: transform .18s ease, box-shadow .18s ease;
        height: 100%;
    }

        .food-card:hover {
            transform: translateY(-3px);
            box-shadow: 0 18px 36px rgba(15,23,42,.1);
        }

    .food-img-wrap {
        position: relative;
        background: #f6f7fb;
        aspect-ratio: 4/3;
        overflow: hidden;
    }

    .food-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform .28s ease;
        display: block;
    }

    .food-card:hover .food-img {
        transform: scale(1.03);
    }

   

    .food-body {
        padding: 10px 12px;
    }

    .food-title {
        font-weight: 900;
        font-size: 1rem;
        color: #111827;
        margin: 0 0 4px;
    }

    .food-desc {
        color: #6b7280;
        font-size: .88rem;
        margin-bottom: 6px;
        min-height: 42px;
    }

    .chip {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 5px 9px;
        border-radius: 999px;
        border: 1px solid #eef1f6;
        background: #f8fafc;
        color: #475569;
        font-size: .8rem;
        margin-inline-end: 6px;
    }

    .price-area {
        display: flex;
        align-items: baseline;
        gap: 8px;
        margin-top: 4px;
    }

    .price-old {
        text-decoration: line-through;
        color: #9ca3af;
        font-size: .9rem;
    }

    .price-new {
        color: #ef4444;
        font-weight: 900;
        font-size: 1rem;
    }

    .food-footer {
        display: flex;
        justify-content: space-between;
        gap: 8px;
        padding: 8px 10px;
        background: #fbfbfc;
        border-top: 1px solid #eef1f6;
    }

        .food-footer .btn {
            border-radius: 8px;
            font-weight: 700;
            padding: .32rem .6rem;
            font-size: .82rem;
        }

    .badge-availability {
        border-radius: 999px;
        padding: .25rem .5rem;
        font-weight: 800;
    }

    /* Not Available */
    .is-unavailable {
        border-color: rgba(239,68,68,.35);
    }

        .is-unavailable .food-img {
            filter: grayscale(100%) contrast(.9) brightness(.9);
        }

        .is-unavailable .food-body, .is-unavailable .food-footer {
            opacity: .7;
        }

        .is-unavailable .food-img-wrap::before {
            content: "";
            position: absolute;
            inset: 0;
            background: repeating-linear-gradient(45deg, rgba(239,68,68,.08) 0 10px, rgba(239,68,68,.16) 10px 20px);
            pointer-events: none;
        }

        .is-unavailable .food-img-wrap::after {
            content: "ناموجود";
            position: absolute;
            inset: 0;
            display: grid;
            place-items: center;
            color: rgba(239,68,68,.9);
            font-weight: 900;
            font-size: 1.05rem;
            transform: rotate(-18deg);
            pointer-events: none;
            text-shadow: 0 2px 8px rgba(0,0,0,.12);
        }

        .is-unavailable .badge-availability {
            background-color: #ef4444 !important;
        }

    /* Minimal on mobile */
    @@media (max-width: 576px) {
        h2

    {
        font-size: 1.05rem;
    }

    .food-toolbar {
        padding: 8px;
    }

        .food-toolbar .form-control, .food-toolbar .form-select {
            font-size: .86rem;
        }

    .food-card {
        border-radius: 10px;
        box-shadow: 0 8px 18px rgba(15,23,42,.06);
    }

    .food-img-wrap {
        aspect-ratio: 1/1;
    }

    .food-body {
        padding: 8px 10px;
    }

    .food-title {
        font-size: .95rem;
        margin-bottom: 2px;
    }

    .food-desc, .chip {
        display: none;
    }

    .price-area {
        gap: 6px;
    }

    .price-old {
        font-size: .8rem;
    }

    .price-new {
        font-size: .95rem;
    }

    .food-footer {
        padding: 7px 9px;
    }

        .food-footer .btn {
            font-size: .76rem;
            padding: .28rem .5rem;
        }

    


    }
    /* جایگزین بخش قیمت و تخفیف در استایل موجود */

    /* قیمت‌ها */
    .price-area {
        display: flex;
        align-items: baseline;
        gap: 8px;
        margin-top: 4px;
        flex-wrap: wrap;
    }

    .price-old {
        text-decoration: line-through;
        color: #9ca3af;
        font-size: 0.85rem;
    }

    .price-new {
        color: #10b981; /* سبز زیبا */
        font-weight: 900;
        font-size: 1rem;
    }

        /* فقط قیمت اصلی (بدون تخفیف) */
        .price-new.no-discount {
            color: #10b981;
        }

    /* بنر تخفیف قرمز */
    .ribbon {
        position: absolute;
        top: 8px;
        right: 8px;
        background: linear-gradient(135deg, #ef4444, #dc2626);
        color: #fff;
        border-radius: 4px 12px 12px 4px;
        padding: 4px 10px;
        font-size: 11px;
        font-weight: 800;
        box-shadow: 0 4px 10px rgba(239, 68, 68, 0.3);
        z-index: 2;
    }

        

    /* کارت تخفیف‌دار */
    .food-card.has-discount .price-new {
        color: #10b981;
        font-size: 1.05rem;
    }

    /* دکمه تخفیف در موبایل */
    @@media (max-width: 576px) {
        .ribbon

    {
        padding: 3px 8px;
        font-size: 9px;
        top: 6px;
        right: 6px;
    }

    .price-new {
        font-size: 0.9rem;
    }

    }
</style>

<div class="container food-page mt-4">
    <div class="d-flex flex-wrap justify-content-between align-items-center mb-3">
       
        <button class="btn btn-primary" onclick="openAddModal()">افزودن غذا</button>
    </div>

    <!-- Filters kept visible, compact on mobile -->
    <div class="food-toolbar mb-3">
        <div class="row g-2 align-items-center">
            <div class="col-12 col-md-4">
                <input id="searchBox" type="text" class="form-control form-control-sm" placeholder="جستجو در نام و توضیحات..." />
            </div>
            <div class="col-6 col-md-3">
                <select id="filterCategory" class="form-select form-select-sm">
                    <option value="">همه دسته‌ها</option>
                </select>
            </div>
            <div class="col-6 col-md-2">
                <select id="filterAvailability" class="form-select form-select-sm">
                    <option value="">همه وضعیت‌ها</option>
                    <option value="true">موجود</option>
                    <option value="false">ناموجود</option>
                </select>
            </div>
            <div class="col-12 col-md-3">
                <select id="sortBy" class="form-select form-select-sm">
                    <option value="newest">جدیدترین</option>
                    <option value="name-asc">نام (الف تا ی)</option>
                    <option value="name-desc">نام (ی تا الف)</option>
                    <option value="price-asc">قیمت (کم به زیاد)</option>
                    <option value="price-desc">قیمت (زیاد به کم)</option>
                    <option value="discount-desc">بیشترین تخفیف</option>
                </select>
            </div>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-warning text-center">غذایی برای نمایش وجود ندارد.</div>
    }
    else
    {
        <div class="row" id="foodList">
            @foreach (var item in Model)
            {
                var hasDiscount = item.DiscountPrice > 0 && item.DiscountPrice != item.Price;
                var discountPercent = hasDiscount ? (int)Math.Round(((item.Price - item.DiscountPrice) / item.Price) * 100) : 0;
                var unavailableClass = item.IsAvailable ? "" : "is-unavailable";
                <div class="col-6 col-md-4 col-lg-3 mb-3"
                     data-id="@item.FoodItemId"
                     data-name="@item.Name"
                     data-description="@item.Description"
                     data-category="@item.CategoryId"
                     data-categoryname="@item.CategoryName"
                     data-price="@item.Price"
                     data-discount="@((hasDiscount ? item.Price - item.DiscountPrice : 0))"
                     data-discountpercent="@discountPercent"
                     data-isavailable="@item.IsAvailable"
                     data-image="@(item.ImageUrl ?? "")">
                    <div class="food-card h-100 @unavailableClass">
                        <div class="food-img-wrap">
                            <img src="@(string.IsNullOrWhiteSpace(item.ImageUrl) ? placeholder : item.ImageUrl)"
                                 class="food-img"
                                 alt="تصویر @item.Name"
                                 loading="lazy"
                                 onerror="this.onerror=null; this.src='@placeholder';" />
                            @if (hasDiscount)
                            {
                                <span class="ribbon">@discountPercent% <span style="font-size: 9px;">تخفیف</span></span>
                            }
                        </div>
                        <div class="food-body">
                            <h5 class="food-title">@item.Name</h5>
                            <p class="food-desc">@item.Description</p>
                            <div class="mb-2">
                                <span class="chip">دسته: @item.CategoryName</span>
                                @if (!item.IsAvailable)
                                {
                                    <span class="badge bg-danger badge-availability">ناموجود</span>
                                }
                                else
                                {
                                    <span class="badge bg-success badge-availability">موجود</span>
                                }
                            </div>
                            <div class="price-area">
                                @if (hasDiscount)
                                {
                                    <span class="price-old">@item.Price.ToString("N0")</span>
                                    <span class="price-new">@item.DiscountPrice.ToString("N0") تومان</span>
                                }
                                else
                                {
                                    <span class="price-new no-discount">@item.Price.ToString("N0") تومان</span>
                                }
                            </div>
                        </div>
                        <div class="food-footer">
                            <button class="btn btn-warning btn-sm" onclick="openEditModal(@item.FoodItemId)">ویرایش</button>
                            <button class="btn btn-danger btn-sm" onclick="deleteFood(@item.FoodItemId)">حذف</button>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

<!-- Modal با پیش‌نمایش تصویر -->
<div class="modal fade" id="foodModal" tabindex="-1">
    <div class="modal-dialog modal-lg modal-dialog-scrollable">
        <div class="modal-content">
            <div id="errorContainer" class="alert alert-danger d-none m-3"></div>
            <div class="modal-header">
                <h5 class="modal-title" id="modalTitle">افزودن غذا</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form id="foodForm" enctype="multipart/form-data">
                    <input type="hidden" id="foodId" name="foodId" />
                    <div class="row g-3">
                        <div class="col-md-7">
                            <div class="mb-3">
                                <label class="form-label">نام غذا <span class="text-danger">*</span></label>
                                <input type="text" id="name" name="name" class="form-control" required />
                            </div>
                            <div class="mb-3">
                                <label class="form-label">توضیحات</label>
<textarea id="description" name="description" class="form-control" rows="3"></textarea>
                            </div>
                            <div class="mb-3">
                                <label for="category" class="form-label">دسته‌بندی <span class="text-danger">*</span></label>
                                <div class="input-group">
                                    <select class="form-select" id="category" name="category" required></select>
                                    <button type="button" id="btnAddCategoryModal" class="btn btn-outline-primary">+ افزودن</button>
                                </div>
                            </div>
                            <div class="row g-2">
                                <div class="col-md-6">
                                    <label class="form-label">قیمت <span class="text-danger">*</span></label>
                                    <input type="number" id="price" name="price" class="form-control" required />
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label">قیمت با تخفیف</label>
                                    <input type="number" id="discountPrice" name="discountPrice" class="form-control" />
                                </div>
                            </div>
                            <div class="form-check mt-3">
                                <input type="checkbox" id="isAvailable" name="isAvailable" class="form-check-input" checked />
                                <label class="form-check-label" for="isAvailable">موجود</label>
                            </div>
                        </div>
                        <div class="col-md-5">
                            <label class="form-label">عکس</label>
                            <input type="file" id="image" name="image" class="form-control mb-2" accept="image/*" />
                            <img id="imgPreview" class="img-preview" src="@placeholder" alt="پیش‌نمایش تصویر" style="width:100%; aspect-ratio:4/3; border:1px dashed #e5e7eb; border-radius:12px; object-fit:cover;">
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" data-bs-dismiss="modal">انصراف</button>
                <button id="btnSaveFood" class="btn btn-primary" onclick="saveFood()">ذخیره</button>
            </div>
        </div>
    </div>
</div>

<script src="~/js/jquery_3.6.0.min.js"></script>
<script src="~/js/bootstrap.bundle.min.js"></script>
<script>
    var restaurantId = @(ViewBag.RestaurantId ?? 0);
    const API_BASE = "https://resturanyar.ir/api/UserApi";
    let compressedImageFile = null;

    // Image compression + preview
    document.getElementById("image").addEventListener("change", async function () {
    if (this.files && this.files[0]) {
    try {
    compressedImageFile = await compressImage(this.files[0], 800, 800, 0.8);
    document.getElementById("imgPreview").src = URL.createObjectURL(compressedImageFile);
    } catch (e) {
    compressedImageFile = this.files[0];
    document.getElementById("imgPreview").src = URL.createObjectURL(this.files[0]);
    }
    } else {
    document.getElementById("imgPreview").src = "@placeholder";
    }
    });

    function compressImage(file, maxW, maxH, q) {
    return new Promise((resolve, reject) => {
    const reader = new FileReader();
    reader.onload = e => {
    const img = new Image();
    img.onload = () => {
    let w = img.width, h = img.height;
    if (w > maxW || h > maxH) {
    const r = Math.min(maxW / w, maxH / h); w *= r; h *= r;
    }
    const c = document.createElement("canvas"); c.width = w; c.height = h;
    const ctx = c.getContext("2d"); ctx.drawImage(img, 0, 0, w, h);
    c.toBlob(b => b ? resolve(new File([b], file.name, { type: "image/jpeg" })) : reject(new Error("blob error")), "image/jpeg", q);
    };
    img.onerror = reject; img.src = e.target.result;
    };
    reader.onerror = reject; reader.readAsDataURL(file);
    });
    }

    // Save (Add/Update)
    function saveFood() {
    clearErrors();
    if (restaurantId === 0) { showErrors(["شناسه رستوران پیدا نشد."]); return; }

    const id = $("#foodId").val();
    const name = $("#name").val().trim();
    const categoryId = parseInt($("#category").val());
    const price = parseInt($("#price").val());
    const discountVal = $("#discountPrice").val();
    const discountPrice = discountVal ? parseInt(discountVal) : null;
    const isAvailable = $("#isAvailable").prop("checked");

    let errors = [];
    if (!name) errors.push("نام غذا الزامی است.");
    else if (name.length < 2) errors.push("نام غذا باید حداقل ۲ کاراکتر باشد.");
    if (isNaN(categoryId) || categoryId <= 0) errors.push("لطفاً یک دسته‌بندی معتبر انتخاب کنید.");
    if (isNaN(price) || price <= 0) errors.push("قیمت باید عددی بزرگ‌تر از صفر باشد.");
    if (discountPrice !== null) {
    if (isNaN(discountPrice)) errors.push("قیمت تخفیف باید عددی معتبر باشد.");
    else if (discountPrice >= price) errors.push("قیمت تخفیف باید کمتر از قیمت اصلی باشد.");
    }
    if (errors.length) { showErrors(errors); return; }

    const fd = new FormData();
    fd.append("RestaurantId", restaurantId);
    fd.append("Name", name);
    fd.append("Description", $("#description").val());
    fd.append("CategoryId", categoryId);
    fd.append("Price", price);
    fd.append("DiscountPrice", discountPrice || 0);
    fd.append("IsAvailable", isAvailable);
    if (id) fd.append("FoodItemId", id);
    if (compressedImageFile) fd.append("Image", compressedImageFile);

    let url = `${API_BASE}/addfood`, method = "POST";
    if (id) { url = `${API_BASE}/updatefood/${id}`; method = "PUT"; }

    const btn = $("#btnSaveFood"), orig = btn.html();
    btn.html('<span class="spinner-border spinner-border-sm me-1"></span> در حال ذخیره...').prop('disabled', true);

    $.ajax({
    url: url,
    type: method,
    data: fd,
    contentType: false,
    processData: false,
    success: function (res) {
    btn.html(orig).prop('disabled', false);
    const ok = res.success || res.Success || false;
    const msg = res.message || res.Message || "عملیات با موفقیت انجام شد";
    alert(msg);
    if (ok) {
    $('#foodModal').modal('hide');
    setTimeout(function(){ location.reload(); }, 500);
    }
    },
    error: function (xhr) {
    btn.html(orig).prop('disabled', false);
    const errorMsg = (xhr.responseJSON && xhr.responseJSON.message) ? xhr.responseJSON.message : "خطا در برقراری ارتباط با سرور";
    showErrors([errorMsg]);
    }
    });
    }

    // Delete
    function deleteFood(id) {
    if (!confirm("آیا از حذف این غذا مطمئن هستید؟")) return;
    $.ajax({
    url: `${API_BASE}/deleteFood/${id}`,
    type: "DELETE",
    success: function (res) {
    const ok = res.success || res.Success || false;
    const msg = res.message || res.Message || "عملیات با موفقیت انجام شد";
    alert(msg);
    if (ok) {
    const card = $(`[data-id='${id}']`);
    card.fadeOut(200, function () {
    $(this).remove();
    if (!$("#foodList [data-id]").length) {
    $("#foodList").html('<div class="col-12"><div class="alert alert-warning text-center">غذایی برای نمایش وجود ندارد.</div></div>');
    }
    });
    }
    },
    error: function () {
    alert("خطا در برقراری ارتباط با سرور");
    }
    });
    }

    // Modal helpers
    function loadCategoriesIntoModal(selectedCategoryId = "", cb) {
    $.ajax({
    url: `${API_BASE}/getcategoriesbyrestaurant/${restaurantId}`,
    type: "GET",
    success: function (data) {
    const select = $("#category");
    select.empty().append('<option value="">-- انتخاب دسته‌بندی --</option>');
    (data.categories || []).forEach(function(cat){
    select.append(`<option value="${cat.categoryId}">${cat.categoryName}</option>`);
    });
    if (selectedCategoryId) select.val(String(selectedCategoryId));
    if (typeof cb === "function") cb();
    },
    error: function () {
    alert("خطا در بارگذاری دسته‌بندی‌ها");
    if (typeof cb === "function") cb();
    }
    });
    }
    function openAddModal() {
    $("#modalTitle").text("افزودن غذا");
    $("#foodForm")[0].reset();
    $("#foodId").val("");
    compressedImageFile = null;
    $("#imgPreview").attr("src", "@placeholder");
    clearErrors();
    loadCategoriesIntoModal("", function () {
    new bootstrap.Modal(document.getElementById("foodModal")).show();
    setTimeout(function(){ $("#name").trigger("focus"); }, 200);
    });
    }
    function openEditModal(id) {
    const card = $(`[data-id='${id}']`);
    if (!card.length) { alert("غذا پیدا نشد!"); return; }

    $("#modalTitle").text("ویرایش غذا");
    $("#foodId").val(id);
    $("#name").val(card.data("name") || "");
    $("#description").val(card.data("description") || "");
    $("#price").val(parseInt(card.data("price")) || 0);
    $("#discountPrice").val(parseInt(card.data("discountpercent")) ? parseInt(card.data("price")) - parseInt(card.data("discount")) : parseInt(card.data("discountprice")) || 0);
    $("#isAvailable").prop("checked",
    card.data("isavailable") === true ||
    card.data("isavailable") === "True" ||
    card.data("isavailable") === "true"
    );
    const img = card.data("image");
    $("#imgPreview").attr("src", img ? img : "@placeholder");
    compressedImageFile = null;
    clearErrors();

    loadCategoriesIntoModal(card.data("category"), function () {
    new bootstrap.Modal(document.getElementById("foodModal")).show();
    });
    }

    // Add Category
    $("#btnAddCategoryModal").on("click", function () {
    const name = prompt("نام دسته‌بندی جدید را وارد کنید:");
    if (name && name.trim() !== "") addCategory(name.trim());
    });
    function addCategory(name) {
    $.ajax({
    url: `${API_BASE}/addcategory`,
    type: "POST",
    contentType: "application/json",
    data: JSON.stringify({ restaurantId: restaurantId, categoryName: name }),
    success: function (d) {
    if (d.success) {
    const id = d.category_id || d.categoryId;
    $("#category").append(`<option value="${id}" selected>${name}</option>`);
    alert(d.message || "دسته‌بندی با موفقیت اضافه شد");
    } else {
    alert("خطا: " + (d.message || "نامشخص"));
    }
    },
    error: function () {
    alert("خطا در برقراری ارتباط با سرور");
    }
    });
    }

    // Errors
    function showErrors(errors) {
    const c = document.getElementById("errorContainer");
    if (!c) return;
    c.innerHTML = '<strong>لطفاً خطاهای زیر را برطرف کنید:</strong>' + errors.map(function(e){ return `<div>• ${e}</div>`; }).join("");
    c.classList.remove("d-none");
    c.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    }
    function clearErrors() {
    const c = document.getElementById("errorContainer");
    if (c) { c.classList.add("d-none"); c.innerHTML = ""; }
    }

    // Filters
    function populateFilterCategories() {
    $.ajax({
    url: `${API_BASE}/getcategoriesbyrestaurant/${restaurantId}`,
    type: "GET",
    success: function (data) {
    const select = $("#filterCategory");
    (data.categories || []).forEach(function(c){
    select.append(`<option value="${c.categoryId}">${c.categoryName}</option>`);
    });
    },
    error: function () {
    const seen = new Set();
    $("#foodList [data-id]").each(function () {
    const id = String($(this).data("category"));
    const name = $(this).data("categoryname");
    if (id && !seen.has(id)) {
    $("#filterCategory").append(`<option value="${id}">${name}</option>`);
    seen.add(id);
    }
    });
    }
    });
    }
    function applyFilters() {
    const q = $("#searchBox").val().trim().toLowerCase();
    const cat = $("#filterCategory").val();
    const avail = $("#filterAvailability").val();
    const sort = $("#sortBy").val();
    const cards = $("#foodList > [data-id]").toArray();

    cards.forEach(function(el){
    const $el = $(el);
    const name = ($el.data("name") || "").toString().toLowerCase();
    const desc = ($el.data("description") || "").toString().toLowerCase();
    const category = String($el.data("category") || "");
    const isAvailable = String($el.data("isavailable")).toLowerCase();
    let ok = true;
    if (q && !(name.includes(q) || desc.includes(q))) ok = false;
    if (cat && category !== String(cat)) ok = false;
    if (avail && isAvailable !== String(avail)) ok = false;
    $el.toggle(ok);
    });

    const visible = $("#foodList > [data-id]:visible").toArray();
    visible.sort(function(a, b){
    const $a = $(a), $b = $(b);
    const nameA = ($a.data("name") || "").toString();
    const nameB = ($b.data("name") || "").toString();
    const priceA = parseInt($a.data("price") || 0);
    const priceB = parseInt($b.data("price") || 0);
    const discA = parseInt($a.data("discount") || 0);
    const discB = parseInt($b.data("discount") || 0);
    switch (sort) {
    case "name-asc": return nameA.localeCompare(nameB, 'fa');
    case "name-desc": return nameB.localeCompare(nameA, 'fa');
    case "price-asc": return priceA - priceB;
    case "price-desc": return priceB - priceA;
    case "discount-desc": return discB - discA;
    default: return 0;
    }
    });
    const container = $("#foodList");
    visible.forEach(function(el){ container.append(el); });
    }

    $(function () {
    populateFilterCategories();
    $("#searchBox, #filterCategory, #filterAvailability, #sortBy").on("input change", applyFilters);
    });
 
</script>

