@{
    ViewData["Title"] = "خطا!";
}

<div class="error-page">
    <div class="error-content">
        <div class="error-icon">🍽️</div>
        <h1>مشکلی پیش آمد</h1>
        <p>
            متأسفانه خطایی در سیستم رخ داده است.<br />
            لطفاً دوباره تلاش کنید یا به صفحه اصلی بازگردید.
        </p>
        <a href="/" class="btn-home">بازگشت به صفحه اصلی</a>
    </div>
</div>

<style>
    body {
        background: linear-gradient(135deg, #ff6f3c, #ff9a3c);
        font-family: 'Tahoma', sans-serif;
        margin: 0;
        padding: 0;
    }

    .error-page {
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .error-content {
        background: #fff;
        padding: 40px;
        border-radius: 20px;
        text-align: center;
        max-width: 480px;
        box-shadow: 0 10px 25px rgba(0,0,0,0.15);
        animation: fadeIn 0.8s ease-in-out;
    }

    .error-icon {
        font-size: 64px;
        margin-bottom: 20px;
        animation: bounce 1.5s infinite;
    }

    .error-content h1 {
        color: #d9534f;
        font-size: 32px;
        margin-bottom: 15px;
    }

    .error-content p {
        color: #444;
        font-size: 18px;
        line-height: 1.7;
        margin-bottom: 30px;
    }

    .btn-home {
        display: inline-block;
        padding: 12px 28px;
        background: #ff6f3c;
        color: #fff;
        font-size: 16px;
        font-weight: bold;
        border-radius: 8px;
        text-decoration: none;
        transition: all 0.3s ease;
    }

        .btn-home:hover {
            background: #e85c2c;
            transform: translateY(-2px);
            box-shadow: 0 4px 10px rgba(0,0,0,0.2);
        }

    /* انیمیشن‌ها */
    @@keyframes fadeIn {
        from

    {
        opacity: 0;
        transform: translateY(20px);
    }

    to {
        opacity: 1;
        transform: translateY(0);
    }

    }

    @@keyframes bounce {
        0%, 100%

    {
        transform: translateY(0);
    }

    50% {
        transform: translateY(-8px);
    }

    }
</style>
