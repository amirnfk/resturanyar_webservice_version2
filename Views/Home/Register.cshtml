@model RegisterOwnerViewModel

<!DOCTYPE html>
<html lang="fa" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>ثبت مدیر رستوران</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.rtl.min.css" rel="stylesheet">
    <link href="~/css/site.css" rel="stylesheet" />

    <style>
        .main-box {
            max-width: 420px;
            margin: -180px auto 0 auto;
        }

        .logo-img {
            width: 90px;
            height: 90px;
            margin: 0 auto;
        }

        .bg-orange {
            background-color: #FF8800;
        }

        .text-orange {
            color: #FF8800;
        }

        .btn-orange {
            background-color: #FF8800;
            color: #fff;
        }

            .btn-orange:hover {
                background-color: #e06e00;
            }
    </style>
</head>
<body class="bg-white">

    <!-- نوار نارنجی بالا -->
    <div class="bg-orange" style="height:220px;"></div>

    <!-- باکس فرم ثبت‌نام -->
    <div class="main-box text-center position-relative">

        <!-- لوگو دایره‌ای -->
        <img src="~/images/logo.png" alt="لوگو" class="rounded-circle bg-white p-3 shadow logo-img" />

        <!-- کارت فرم ثبت‌نام -->
        <div class="card mt-4 shadow rounded-4">
            <div class="card-body px-4 py-5 text-start">

                <h5 class="text-orange fw-bold text-center mb-4">ثبت‌نام مدیر رستوران</h5>

                <form asp-action="Register" method="post">
                    <div class="mb-3">
                        <label asp-for="Name" class="form-label">نام</label>
                        <input asp-for="Name" class="form-control form-control-lg text-end" placeholder="نام کامل" />
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Phone" class="form-label">شماره تلفن</label>
                        <input asp-for="Phone" class="form-control form-control-lg text-end" placeholder="مثلاً 09121234567" />
                        <span asp-validation-for="Phone" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Password" class="form-label">رمز عبور</label>
                        <input asp-for="Password" type="password" class="form-control form-control-lg text-end" placeholder="رمز عبور" />
                        <span asp-validation-for="Password" class="text-danger"></span>
                    </div>

                    <div class="d-grid mt-4">
                        <button type="submit" class="btn btn-orange btn-lg fw-bold">ثبت‌نام</button>
                    </div>

                    @if (ViewBag.Error != null)
                    {
                        <div class="alert alert-danger mt-3 text-center">@ViewBag.Error</div>
                    }
                    @if (ViewBag.Success != null)
                    {
                        <div class="alert alert-success mt-3 text-center">@ViewBag.Success</div>
                    }
                </form>
            </div>
        </div>

        <!-- تصویر پایین (اختیاری) -->
        <img src="~/images/bergerback.jpg" alt="پس‌زمینه" class="img-fluid mt-4" style="max-height: 240px; object-fit: contain;" />

    </div>

    @section Scripts {
        <partial name="_ValidationScriptsPartial" />
    }
</body>
</html>
