@{
    ViewData["Title"] = "نتیجه پرداخت";
    Layout = null; // Use null to apply our full-page design, or remove if your layout already supports clean embedding
}
<!DOCTYPE html>
<html lang="fa" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"]</title>
    <link href="https://cdn.jsdelivr.net/gh/rastikerdar/vazirmatn@v33.003/Vazirmatn-font-face.css" rel="stylesheet" />
    <style>
        :root {
            --bg-deep: #08090d;
            --bg-card: rgba(20, 22, 30, 0.75);
            --gold: #c9a96e;
            --gold-light: #e0c78a;
            --gold-dark: #a07d3e;
            --text-primary: #f0ede6;
            --text-secondary: #b8b5ad;
            --success-glow: rgba(201, 169, 110, 0.5);
            --danger-accent: #c47a6b;
            --danger-bg: rgba(40, 22, 20, 0.8);
            --border-glass: rgba(255, 255, 255, 0.08);
            --shadow-card: 0 30px 70px rgba(0, 0, 0, 0.6), 0 0 0 1px rgba(255, 255, 255, 0.04) inset;
            --transition-smooth: cubic-bezier(0.22, 0.61, 0.36, 1);
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'IRANYekan', 'Segoe UI', system-ui, sans-serif;
            background: var(--bg-deep);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            overflow: hidden;
            position: relative;
            -webkit-font-smoothing: antialiased;
            -moz-osx-font-smoothing: grayscale;
        }

        /* ── Animated background orbs ── */
        .bg-orb {
            position: absolute;
            border-radius: 50%;
            filter: blur(120px);
            opacity: 0.18;
            pointer-events: none;
            animation: orbFloat 20s infinite ease-in-out;
        }

        .bg-orb--1 {
            width: 600px;
            height: 600px;
            background: radial-gradient(circle, #2a2415 0%, transparent 70%);
            top: -20%;
            left: -15%;
            animation-delay: 0s;
        }

        .bg-orb--2 {
            width: 500px;
            height: 500px;
            background: radial-gradient(circle, #1a1d2e 0%, transparent 70%);
            bottom: -25%;
            right: -10%;
            animation-delay: -7s;
            animation-duration: 24s;
        }

        .bg-orb--3 {
            width: 350px;
            height: 350px;
            background: radial-gradient(circle, #1e1a14 0%, transparent 70%);
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            animation-delay: -14s;
            animation-duration: 18s;
        }

        @@keyframes orbFloat {
            0%, 100% {
                transform: translate(0, 0) scale(1);
            }

            25% {
                transform: translate(60px, -40px) scale(1.08);
            }

            50% {
                transform: translate(-30px, 50px) scale(0.94);
            }

            75% {
                transform: translate(-50px, -20px) scale(1.05);
            }
        }

        /* ── Subtle grid texture overlay ── */
        .grid-texture {
            position: fixed;
            inset: 0;
            pointer-events: none;
            z-index: 0;
            opacity: 0.03;
            background-image: linear-gradient(rgba(255,255,255,0.3) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.3) 1px, transparent 1px);
            background-size: 60px 60px;
            mask-image: radial-gradient(ellipse at center, black 30%, transparent 70%);
        }

        /* ── Main card container ── */
        .card-wrapper {
            position: relative;
            z-index: 10;
            width: 90%;
            max-width: 560px;
            animation: cardEntrance 0.9s var(--transition-smooth) forwards;
            opacity: 0;
            transform: translateY(40px) scale(0.96);
        }

        @@keyframes cardEntrance {
            to {
                opacity: 1;
                transform: translateY(0) scale(1);
            }
        }

        .premium-card {
            background: var(--bg-card);
            backdrop-filter: blur(40px);
            -webkit-backdrop-filter: blur(40px);
            border-radius: 28px;
            padding: 50px 40px 40px;
            border: 1px solid var(--border-glass);
            box-shadow: var(--shadow-card);
            text-align: center;
            position: relative;
            overflow: hidden;
            transition: box-shadow 0.6s var(--transition-smooth);
        }

            /* Shimmer border on success */
            .premium-card.success-card {
                box-shadow: var(--shadow-card), 0 0 80px rgba(201, 169, 110, 0.12);
            }

                .premium-card.success-card::before {
                    content: '';
                    position: absolute;
                    top: -1px;
                    left: -1px;
                    right: -1px;
                    bottom: -1px;
                    border-radius: 28px;
                    padding: 1.5px;
                    background: linear-gradient(135deg, transparent 20%, rgba(201, 169, 110, 0.5) 40%, rgba(224, 199, 138, 0.7) 50%, rgba(201, 169, 110, 0.5) 60%, transparent 80%);
                    background-size: 300% 300%;
                    -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
                    mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
                    -webkit-mask-composite: xor;
                    mask-composite: exclude;
                    animation: shimmerBorder 4s infinite linear;
                    z-index: 0;
                    pointer-events: none;
                }

        @@keyframes shimmerBorder {
            0% {
                background-position: 0% 50%;
            }

            50% {
                background-position: 100% 50%;
            }

            100% {
                background-position: 0% 50%;
            }
        }

        .premium-card.danger-card {
            box-shadow: var(--shadow-card), 0 0 50px rgba(196, 122, 107, 0.08);
        }

        /* ── Icon container ── */
        .icon-container {
            position: relative;
            display: inline-block;
            margin-bottom: 28px;
            z-index: 1;
        }

        .icon-circle {
            width: 100px;
            height: 100px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            position: relative;
        }

            .icon-circle.success {
                background: radial-gradient(circle at 40% 35%, rgba(201,169,110,0.35) 0%, rgba(160,125,62,0.15) 50%, transparent 70%);
                box-shadow: 0 0 60px rgba(201, 169, 110, 0.25), 0 0 0 1px rgba(201, 169, 110, 0.2) inset;
            }

            .icon-circle.danger {
                background: radial-gradient(circle at 40% 35%, rgba(196,122,107,0.3) 0%, rgba(160,80,65,0.12) 50%, transparent 70%);
                box-shadow: 0 0 50px rgba(196, 122, 107, 0.2), 0 0 0 1px rgba(196, 122, 107, 0.15) inset;
            }

            /* Animated ring */
            .icon-circle::after {
                content: '';
                position: absolute;
                inset: -6px;
                border-radius: 50%;
                border: 1.5px solid transparent;
                animation: ringPulse 2.5s infinite ease-out;
                pointer-events: none;
            }

            .icon-circle.success::after {
                border-color: rgba(201, 169, 110, 0.4);
                animation-name: ringPulseGold;
            }

            .icon-circle.danger::after {
                border-color: rgba(196, 122, 107, 0.35);
                animation-name: ringPulseDanger;
            }

        @@keyframes ringPulseGold {
            0% {
                inset: -6px;
                opacity: 0.9;
            }

            100% {
                inset: -28px;
                opacity: 0;
            }
        }

        @@keyframes ringPulseDanger {
            0% {
                inset: -6px;
                opacity: 0.8;
            }

            100% {
                inset: -24px;
                opacity: 0;
            }
        }

        /* Checkmark SVG */
        .icon-svg {
            width: 48px;
            height: 48px;
            position: relative;
            z-index: 2;
        }

            .icon-svg.success-svg {
                color: var(--gold-light);
                filter: drop-shadow(0 0 12px rgba(201, 169, 110, 0.6));
            }

            .icon-svg.danger-svg {
                color: var(--danger-accent);
                filter: drop-shadow(0 0 10px rgba(196, 122, 107, 0.5));
            }

        /* Checkmark draw animation */
        .check-path {
            stroke-dasharray: 70;
            stroke-dashoffset: 70;
            animation: drawCheck 0.7s 0.3s var(--transition-smooth) forwards;
        }

        @@keyframes drawCheck {
            to {
                stroke-dashoffset: 0;
            }
        }

        .cross-path {
            stroke-dasharray: 55;
            stroke-dashoffset: 55;
            animation: drawCheck 0.6s 0.3s var(--transition-smooth) forwards;
        }

        /* ── Typography ── */
        .status-title {
            font-size: 1.9rem;
            font-weight: 700;
            letter-spacing: -0.3px;
            margin-bottom: 10px;
            position: relative;
            z-index: 1;
            line-height: 1.3;
        }

            .status-title.success-title {
                color: var(--gold-light);
                text-shadow: 0 0 40px rgba(201, 169, 110, 0.3);
            }

            .status-title.danger-title {
                color: #e8b4ab;
                text-shadow: 0 0 30px rgba(196, 122, 107, 0.25);
            }

        .status-message {
            font-size: 1.05rem;
            font-weight: 400;
            color: var(--text-secondary);
            line-height: 1.8;
            margin-bottom: 32px;
            position: relative;
            z-index: 1;
            max-width: 380px;
            margin-left: auto;
            margin-right: auto;
        }

            .status-message .highlight {
                color: var(--text-primary);
                font-weight: 500;
            }

        /* ── Divider ── */
        .divider {
            width: 60px;
            height: 2px;
            margin: 0 auto 28px;
            border-radius: 1px;
            position: relative;
            z-index: 1;
        }

            .divider.success-divider {
                background: linear-gradient(90deg, transparent, var(--gold), transparent);
            }

            .divider.danger-divider {
                background: linear-gradient(90deg, transparent, rgba(196, 122, 107, 0.5), transparent);
            }

        /* ── Button ── */
        .btn-premium {
            display: inline-block;
            padding: 14px 40px;
            font-family: 'IRANYekan', 'Segoe UI', system-ui, sans-serif;
            font-size: 1rem;
            font-weight: 500;
            text-decoration: none;
            border-radius: 50px;
            position: relative;
            z-index: 1;
            transition: all 0.4s var(--transition-smooth);
            letter-spacing: 0.2px;
            cursor: pointer;
            border: none;
            outline: none;
        }

            .btn-premium.success-btn {
                background: linear-gradient(135deg, #b8934f 0%, #d4b87a 40%, #c9a96e 60%, #a07d3e 100%);
                color: #1a1810;
                box-shadow: 0 8px 30px rgba(180, 140, 60, 0.3);
                background-size: 200% 200%;
                animation: btnShimmer 3s infinite linear;
            }

                .btn-premium.success-btn:hover {
                    box-shadow: 0 14px 40px rgba(200, 155, 70, 0.45);
                    transform: translateY(-3px);
                    color: #0d0b06;
                }

            .btn-premium.danger-btn {
                background: rgba(255, 255, 255, 0.06);
                color: var(--text-primary);
                border: 1px solid rgba(255, 255, 255, 0.2);
                box-shadow: 0 6px 20px rgba(0, 0, 0, 0.3);
            }

                .btn-premium.danger-btn:hover {
                    background: rgba(255, 255, 255, 0.12);
                    border-color: rgba(255, 255, 255, 0.35);
                    transform: translateY(-3px);
                    box-shadow: 0 12px 30px rgba(0, 0, 0, 0.4);
                }

        @@keyframes btnShimmer {
            0% {
                background-position: 0% 50%;
            }

            50% {
                background-position: 100% 50%;
            }

            100% {
                background-position: 0% 50%;
            }
        }

        /* ── Sparkle particles (success only) ── */
        .sparkle-container {
            position: absolute;
            inset: 0;
            pointer-events: none;
            z-index: 0;
            overflow: hidden;
            border-radius: 28px;
        }

        .sparkle {
            position: absolute;
            width: 4px;
            height: 4px;
            background: var(--gold-light);
            border-radius: 50%;
            animation: sparkleFloat 3s infinite ease-in;
            opacity: 0;
        }

            .sparkle:nth-child(1) {
                top: 15%;
                left: 15%;
                animation-delay: 0s;
                width: 5px;
                height: 5px;
            }

            .sparkle:nth-child(2) {
                top: 20%;
                right: 18%;
                animation-delay: 0.6s;
                width: 3px;
                height: 3px;
            }

            .sparkle:nth-child(3) {
                top: 70%;
                left: 20%;
                animation-delay: 1.2s;
                width: 4px;
                height: 4px;
            }

            .sparkle:nth-child(4) {
                top: 65%;
                right: 15%;
                animation-delay: 1.8s;
                width: 6px;
                height: 6px;
            }

            .sparkle:nth-child(5) {
                top: 40%;
                left: 8%;
                animation-delay: 2.4s;
                width: 3px;
                height: 3px;
            }

            .sparkle:nth-child(6) {
                top: 35%;
                right: 10%;
                animation-delay: 0.9s;
                width: 5px;
                height: 5px;
            }

            .sparkle:nth-child(7) {
                top: 80%;
                left: 40%;
                animation-delay: 1.5s;
                width: 4px;
                height: 4px;
            }

            .sparkle:nth-child(8) {
                top: 10%;
                left: 50%;
                animation-delay: 2.1s;
                width: 3px;
                height: 3px;
            }

        @@keyframes sparkleFloat {
            0% {
                opacity: 0;
                transform: translateY(0) scale(0.3);
            }

            20% {
                opacity: 0.9;
            }

            50% {
                opacity: 0.5;
                transform: translateY(-25px) scale(1.4);
            }

            100% {
                opacity: 0;
                transform: translateY(-50px) scale(0.2);
            }
        }

        /* ── Responsive ── */
        @@media (max-width: 480px) {
            .premium-card {
                padding: 36px 22px 30px;
                border-radius: 22px;
            }

                .premium-card.success-card::before {
                    border-radius: 22px;
                }

            .status-title {
                font-size: 1.5rem;
            }

            .status-message {
                font-size: 0.95rem;
                max-width: 280px;
            }

            .icon-circle {
                width: 80px;
                height: 80px;
            }

            .icon-svg {
                width: 38px;
                height: 38px;
            }

            .btn-premium {
                padding: 12px 32px;
                font-size: 0.9rem;
            }
        }
    </style>
</head>
<body>
    <!-- Background orbs -->
    <div class="bg-orb bg-orb--1"></div>
    <div class="bg-orb bg-orb--2"></div>
    <div class="bg-orb bg-orb--3"></div>
    <div class="grid-texture"></div>

    <!-- Card -->
    <div class="card-wrapper">
        <div class="premium-card @(ViewBag.Success == true ? "success-card" : "danger-card")">

            @if (ViewBag.Success == true)
            {
                <!-- Sparkles for success -->
                <div class="sparkle-container">
                    <span class="sparkle"></span><span class="sparkle"></span>
                    <span class="sparkle"></span><span class="sparkle"></span>
                    <span class="sparkle"></span><span class="sparkle"></span>
                    <span class="sparkle"></span><span class="sparkle"></span>
                </div>

                <!-- Success Icon -->
                <div class="icon-container">
                    <div class="icon-circle success">
                        <svg class="icon-svg success-svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                            <polyline class="check-path" points="4 13 9 18 20 6" />
                        </svg>
                    </div>
                </div>

                <h2 class="status-title success-title">با سپاس از شما</h2>
                <div class="divider success-divider"></div>
                <p class="status-message">
                    <span class="highlight">پرداخت شما با موفقیت انجام شد.</span><br />
                    @ViewBag.Message
                </p>

                <a href="/Home/ChooseRestaurant" class="btn-premium success-btn">
                    بازگشت به داشبورد
                </a>
            }
            else
            {
                <!-- Failure Icon -->
                <div class="icon-container">
                    <div class="icon-circle danger">
                        <svg class="icon-svg danger-svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                            <line class="cross-path" x1="6" y1="6" x2="18" y2="18" />
                            <line class="cross-path" x1="18" y1="6" x2="6" y2="18" style="animation-delay: 0.15s;" />
                        </svg>
                    </div>
                </div>

                <h2 class="status-title danger-title">پرداخت ناموفق</h2>
                <div class="divider danger-divider"></div>
                <p class="status-message">
                    متأسفانه پرداخت شما با خطا مواجه شد.<br />
                    <span style="font-size: 0.9rem; opacity: 0.75;">@ViewBag.Message</span>
                </p>

                <a href="/Home/ChooseRestaurant" class="btn-premium danger-btn">
                    بازگشت به داشبورد
                </a>
            }
        </div>
    </div>
</body>
</html>