@model List<FoodItemViewModel>
@{
    ViewData["Title"] = "ثبت سفارش جدید";
    var placeholder = Url.Content("~/images/food_placeholder.jpg");
}

<link href="~/css/bootstrap_rtl_min.css" rel="stylesheet" />
@* <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" /> *@

<style>
    :root {
        --primary: #ff7a00;
        --primary-hover: #e66900;
        --primary-light: rgba(255, 122, 0, 0.12);
        --primary-glow: rgba(255, 122, 0, 0.25);
        --bg-page: #f8fafc;
        --card-bg: #ffffff;
        --card-border: #eef2f8;
        --shadow-sm: 0 2px 8px rgba(0, 0, 0, 0.04), 0 0 0 1px rgba(0, 0, 0, 0.02);
        --shadow-md: 0 8px 24px rgba(0, 0, 0, 0.06), 0 0 0 1px rgba(0, 0, 0, 0.02);
        --shadow-lg: 0 20px 32px -12px rgba(0, 0, 0, 0.12), 0 0 0 1px rgba(0, 0, 0, 0.03);
        --shadow-xl: 0 32px 48px -16px rgba(0, 0, 0, 0.16);
        --text-dark: #0f172a;
        --text-muted: #475569;
        --text-light: #94a3b8;
        --radius-xs: 8px;
        --radius-sm: 12px;
        --radius-md: 18px;
        --radius-lg: 24px;
        --radius-pill: 9999px;
        --transition-fast: 0.15s cubic-bezier(0.4, 0, 0.2, 1);
        --transition: 0.25s cubic-bezier(0.4, 0, 0.2, 1);
        --transition-slow: 0.35s cubic-bezier(0.4, 0, 0.2, 1);
        --safe-bottom: env(safe-area-inset-bottom, 0px);
    }

 

    body {
        background: var(--bg-page);
        direction: rtl;
        font-family: "IRANYekan", "IRANYekan", system-ui, -apple-system, "Segoe UI", Roboto, sans-serif;
        color: var(--text-dark);
        line-height: 1.5;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
    }

    

    /* Scrollbar Styling */
    ::-webkit-scrollbar {
        width: 8px;
        height: 8px;
    }

    ::-webkit-scrollbar-track {
        background: #eef2f8;
        border-radius: var(--radius-pill);
    }

    ::-webkit-scrollbar-thumb {
        background: #cbd5e1;
        border-radius: var(--radius-pill);
        transition: var(--transition-fast);
    }

        ::-webkit-scrollbar-thumb:hover {
            background: var(--primary);
        }

    /* Typography improvements */
    h1, h2, h3, h4, h5, h6 {
        letter-spacing: -0.02em;
        font-weight: 800;
    }

    .fw-black {
        font-weight: 900 !important;
        letter-spacing: -0.02em;
    }

    .text-muted {
        color: var(--text-muted) !important;
    }

    /* ── TOOLBAR ── */
    .food-toolbar {
        background: var(--card-bg);
        backdrop-filter: blur(0px);
        border: 1px solid var(--card-border);
        border-radius: var(--radius-md);
        box-shadow: var(--shadow-sm);
        padding: 16px 20px;
        transition: var(--transition);
    }

        .food-toolbar .form-control,
        .food-toolbar .form-select  {
            font-family: "IRANYekan", "IRANYekan", system-ui, -apple-system, "Segoe UI", Roboto, sans-serif;
            border-radius: var(--radius-sm);
            border: 1px solid #e2e8f0;
            font-size: 0.775rem;
            padding: 10px 14px;
            background: #fff;
            transition: var(--transition);
        }

            .food-toolbar .form-control:focus,
            .food-toolbar .form-select:focus {
                border-color: var(--primary);
                box-shadow: 0 0 0 3px var(--primary-light);
                outline: none;
            }

   
    /* ── BUTTONS ── */
    .btn-primary {
        background: linear-gradient(135deg, var(--primary), #f97316);
        border: none;
        border-radius: var(--radius-sm);
        font-weight: 700;
        padding: 10px 20px;
        box-shadow: 0 4px 12px var(--primary-glow);
        transition: all var(--transition);
        position: relative;
        overflow: hidden;
    }

        .btn-primary::before {
            content: '';
            position: absolute;
            top: 50%;
            left: 50%;
            width: 0;
            height: 0;
            border-radius: 50%;
            background: rgba(255, 255, 255, 0.3);
            transform: translate(-50%, -50%);
            transition: width 0.5s, height 0.5s;
        }

        .btn-primary:active::before {
            width: 300px;
            height: 300px;
        }

        .btn-primary:hover {
            background: linear-gradient(135deg, #f97316, var(--primary-hover));
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(255, 122, 0, 0.4);
        }

        .btn-primary:active {
            transform: translateY(0);
            box-shadow: 0 4px 12px rgba(255, 122, 0, 0.2);
        }

    .btn-new-customer {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 0 18px;
        height: 42px;
        background: linear-gradient(135deg, var(--primary), #f97316);
        color: #fff;
        border: none;
        border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
        font-size: 0.85rem;
        font-weight: 800;
        font-family: "IRANYekan", "IRANYekan", system-ui, -apple-system, "Segoe UI", Roboto, sans-serif;
        cursor: pointer;
        white-space: nowrap;
        transition: all var(--transition);
        flex-shrink: 0;
        box-shadow: 0 2px 6px rgba(0, 0, 0, 0.1);
    }

        .btn-new-customer:hover {
            background: linear-gradient(135deg, #f97316, var(--primary-hover));
            transform: translateX(-2px);
            box-shadow: 0 4px 12px rgba(255, 122, 0, 0.3);
        }

        .btn-new-customer:active {
            transform: scale(0.97);
        }

    /* ── FOOD CARD (Enhanced) ── */
    .food-card {
        position: relative;
        border: 1px solid var(--card-border);
        border-radius: var(--radius-lg);
        overflow: hidden;
        background: var(--card-bg);
        box-shadow: var(--shadow-sm);
        transition: all var(--transition);
        height: 100%;
        display: flex;
        flex-direction: column;
        cursor: pointer;
    }

        .food-card::after {
            content: '';
            position: absolute;
            inset: 0;
            border-radius: inherit;
            pointer-events: none;
            transition: var(--transition);
            box-shadow: 0 0 0 0 rgba(255, 122, 0, 0);
        }

        .food-card:hover {
            transform: translateY(-8px) scale(1.01);
            box-shadow: var(--shadow-xl);
            border-color: transparent;
        }

            .food-card:hover::after {
                box-shadow: 0 0 0 1px var(--primary);
            }

        .food-card.is-unavailable {
            opacity: 0.65;
            filter: grayscale(30%);
            pointer-events: none;
        }

    .food-img-wrap {
        position: relative;
        background: linear-gradient(145deg, #f1f5f9, #eef2f8);
        aspect-ratio: 4/3;
        overflow: hidden;
    }

    .food-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform var(--transition-slow);
    }

    .food-card:hover .food-img {
        transform: scale(1.08);
    }

    .ribbon {
        position: absolute;
        top: 12px;
        left: 12px;
        background: linear-gradient(135deg, #f00, #f00);
        color: #fff;
        border-radius: var(--radius-pill);
        padding: 5px 12px;
        font-size: 0.7rem;
        font-weight: 800;
        box-shadow: 0 4px 12px rgba(34, 197, 94, 0.4);
        z-index: 2;
        backdrop-filter: blur(2px);
        letter-spacing: -0.3px;
    }

    .food-card.is-unavailable .food-img-wrap::after {
        content: "❌ ناموجود";
        position: absolute;
        inset: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        background: rgba(0, 0, 0, 0.65);
        color: #fff;
        font-weight: 900;
        font-size: 1.1rem;
        backdrop-filter: blur(4px);
        z-index: 3;
    }

    .food-body {
        padding: 14px 16px;
        flex: 1;
        display: flex;
        flex-direction: column;
    }

    .food-title {
        font-weight: 800;
        font-size: 1.1rem;
        color: var(--text-dark);
        margin-bottom: 6px;
        line-height: 1.4;
    }

    .food-desc {
        color: var(--text-muted);
        font-size: 0.8rem;
        margin-bottom: 12px;
        flex: 1;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .chip {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 5px 12px;
        border-radius: var(--radius-pill);
        background: #f8fafc;
        border: 1px solid #e2e8f0;
        color: #334155;
        font-size: 0.7rem;
        font-weight: 600;
        transition: var(--transition-fast);
    }

        .chip:hover {
            border-color: var(--primary-light);
            background: #fff;
        }

    .badge-availability {
        border-radius: var(--radius-pill);
        padding: 5px 12px;
        font-weight: 700;
        font-size: 0.7rem;
    }

    .price-area {
        display: flex;
        align-items: baseline;
        gap: 12px;
        margin-top: 8px;
        flex-wrap: wrap;
    }

    .price-old {
        text-decoration: line-through;
        color: var(--text-light);
        font-size: 0.85rem;
    }

    .price-new {

        color: green;
        font-weight: 900;
        font-size: 1.1rem;
    }

    .food-footer {
        padding: 12px 16px;
        background: #fafcff;
        border-top: 1px solid #f0f4fa;
        display: flex;
        justify-content: center;
    }

        .food-footer .btn {
            width: 100%;
            border-radius: var(--radius-sm);
            font-weight: 800;
            font-size: 0.85rem;
            padding: 8px 0;
        }

    /* ── CART SIDEBAR (Enhanced) ── */
    .cart-sidebar {
        position: sticky;
        top: 24px;
        background: var(--card-bg);
        border-radius: var(--radius-lg);
        box-shadow: var(--shadow-lg);
        border: 1px solid var(--card-border);
        padding: 24px;
        transition: var(--transition);
    }

        .cart-sidebar:hover {
            box-shadow: var(--shadow-xl);
        }

    .cart-title {
        font-weight: 900;
        font-size: 1.35rem;
        color: #0f172a;
        border-bottom: 3px solid var(--primary);
        display: inline-block;
        padding-bottom: 8px;
        margin-bottom: 1.5rem;
        letter-spacing: -0.5px;
    }

    .cart-item {
        display: flex;
        flex-wrap: wrap;
        justify-content: space-between;
        align-items: center;
        gap: 8px;
        font-size: 0.85rem;
        padding: 12px 0;
        border-bottom: 1px solid #eef2f8;
        transition: var(--transition-fast);
    }

        .cart-item:hover {
            background: #fafcff;
            padding-right: 8px;
            border-radius: var(--radius-sm);
        }

    .cart-item-info strong {
        display: block;
        color: var(--text-dark);
        font-size: 0.9rem;
    }

    .cart-item-actions {
        display: flex;
        gap: 8px;
        align-items: center;
    }

        .cart-item-actions input {
            width: 65px;
            text-align: center;
            padding: 6px;
            border-radius: var(--radius-sm);
            border: 1px solid #cbd5e1;
            font-weight: 600;
            transition: var(--transition);
        }

            .cart-item-actions input:focus {
                border-color: var(--primary);
                outline: none;
                box-shadow: 0 0 0 2px var(--primary-light);
            }

    .remove-item-btn {
        background: #fee2e2;
        border: none;
        color: #dc2626;
        border-radius: var(--radius-sm);
        padding: 5px 12px;
        font-weight: 700;
        font-size: 0.75rem;
        transition: var(--transition);
        cursor: pointer;
    }

        .remove-item-btn:hover {
            background: #fecaca;
            color: #b91c1c;
            transform: scale(1.02);
        }

    .cart-total {
        font-weight: 900;
        font-size: 1.2rem;
        border-top: 2px solid #e2e8f0;
        padding-top: 16px;
        margin-top: 12px;
        color: var(--text-dark);
    }

    .empty-cart {
        text-align: center;
        color: var(--text-light);
        padding: 32px 0;
        font-style: italic;
    }


    .cart-fab {
        position: fixed;
        inset-inline-end: 16px;
        inset-block-end: calc(20px + var(--safe-bottom));
        z-index: 1050;
        border: none;
        border-radius: 48px;
        background: linear-gradient(135deg, var(--primary), #0f172a);
        color: white;
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 12px 20px;
        box-shadow: var(--shadow-lg);
        font-weight: 800;
        font-size: 0.9rem;
        cursor: pointer;
        backdrop-filter: blur(8px);
        transition: var(--transition);
    }

        .cart-fab:hover {
            transform: translateY(-4px);
            box-shadow: var(--shadow-xl);
        }

        .cart-fab .badge {
            background: rgba(255, 255, 255, 0.25);
            border-radius: 40px;
            padding: 5px 12px;
            margin: 0;
        }


    .cart-offcanvas .offcanvas-header {
        border-bottom: 2px solid var(--primary-light);
        background: #fff;
    }

    .cart-offcanvas .offcanvas-body {
        padding: 1.5rem;
        background: #fefefe;
    }

  
    .customer-search-wrapper {
        position: relative;
    }

    .customer-search-results {
        position: absolute;
        top: calc(100% + 8px);
        left: 0;
        right: 0;
        z-index: 1060;
        background: white;
        border-radius: var(--radius-md);
        box-shadow: var(--shadow-lg);
        border: 1px solid var(--card-border);
        max-height: 320px;
        overflow-y: auto;
        animation: slideDown 0.2s ease-out;
    }

    @@keyframes slideDown {
        from

    {
        opacity: 0;
        transform: translateY(-10px);
    }

    to {
        opacity: 1;
        transform: translateY(0);
    }

    }

    .customer-result-item {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 14px 16px;
        border-bottom: 1px solid #f1f5f9;
        cursor: pointer;
        transition: background var(--transition-fast);
    }

        .customer-result-item:last-child {
            border-bottom: none;
        }

        .customer-result-item:hover {
            background: var(--primary-light);
        }

        .customer-result-item .customer-mobile {
            font-weight: 800;
            color: var(--text-dark);
            font-size: 0.9rem;
            direction: ltr;
        }

        .customer-result-item .customer-name {
            font-size: 0.8rem;
            color: var(--text-muted);
        }

    .selected-customer-card {
        background: linear-gradient(135deg, var(--primary-light), rgba(255, 122, 0, 0.05));
        border-radius: var(--radius-sm);
        padding: 12px 16px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-top: 12px;
        border: 1px solid rgba(255, 122, 0, 0.2);
    }

        .selected-customer-card .customer-detail {
            font-size: 0.85rem;
        }

    .btn-change-customer {
        background: none;
        border: none;
        color: var(--primary);
        font-weight: 800;
        font-size: 0.75rem;
        padding: 6px 12px;
        cursor: pointer;
        transition: var(--transition);
        border-radius: var(--radius-pill);
    }

        .btn-change-customer:hover {
            background: #fff;
            transform: scale(1.02);
        }

   
    .toast-container {
        position: fixed;
        bottom: 24px;
        left: 24px;
        z-index: 1100;
        direction: rtl;
    }

    .custom-toast {
        background: #fff;
        border-radius: var(--radius-md);
        box-shadow: var(--shadow-lg);
        border-right: 5px solid;
        padding: 0;
        overflow: hidden;
        font-size: 0.9rem;
        animation: toastSlideIn 0.3s cubic-bezier(0.68, -0.55, 0.265, 1.55);
        backdrop-filter: blur(10px);
    }

        .custom-toast.toast-success {
            border-right-color: #22c55e;
            background: linear-gradient(135deg, #fff, #f0fdf4);
        }

        .custom-toast.toast-error {
            border-right-color: #ef4444;
            background: linear-gradient(135deg, #fff, #fef2f2);
        }

        .custom-toast.toast-info {
            border-right-color: #3b82f6;
            background: linear-gradient(135deg, #fff, #eff6ff);
        }

        .custom-toast .toast-header {
            background: transparent;
            border-bottom: 1px solid #f0f2f5;
            font-weight: 800;
            padding: 12px 16px;
        }

        .custom-toast .toast-body {
            padding: 14px 16px;
            color: #1e293b;
        }

    @@keyframes toastSlideIn {
        from

    {
        opacity: 0;
        transform: translateX(-40px) scale(0.9);
    }

    to {
        opacity: 1;
        transform: translateX(0) scale(1);
    }

    }

  
    .modal-content {
        border: none;
        border-radius: var(--radius-lg);
        box-shadow: var(--shadow-xl);
        overflow: hidden;
    }

    .modal-header {
        background: linear-gradient(135deg, #fff, #fafcff);
        border-bottom: 1px solid var(--card-border);
        padding: 1.25rem 1.5rem;
    }

    .modal-footer {
        background: #fafcff;
        border-top: 1px solid var(--card-border);
        padding: 1rem 1.5rem;
    }


    @@media (hover: none) and (pointer: coarse) {
        .add-to-cart-btn, .remove-item-btn, #submitOrderBtn, #offcanvasSubmitOrderBtn, .cart-fab

    {
        min-height: 48px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .cart-item-actions input[type="number"] {
        min-height: 42px;
        font-size: 1rem;
    }

    .food-card:hover {
        transform: translateY(-4px);
    }

        .food-card:hover .food-img {
            transform: scale(1.04);
        }

    }

    @@media (max-width: 768px) {
        .food-toolbar

    {
        padding: 12px 16px;
    }

    .cart-sidebar {
        padding: 16px;
    }

    .food-body {
        padding: 10px 12px;
    }

    .food-title {
        font-size: 1rem;
    }

        .cart-sidebar{
            display:none;
        }

    }

    @@media (max-width: 576px) {
        #desktopCustomerSearch, #offcanvasCustomerSearch

    {
        font-size: 16px !important;
    }

    .selected-customer-card {
        flex-direction: column;
        align-items: flex-start;
        gap: 10px;
    }

    .price-area {
        flex-direction: column;
        align-items: flex-start;
        gap: 4px;
    }

    }

    /* Animations for food items */
    .food-card-item {
        animation: fadeInUp 0.4s ease-out backwards;
        animation-delay: calc(var(--item-index, 0) * 0.03s);
    }

    @@keyframes fadeInUp {
        from

    {
        opacity: 0;
        transform: translateY(20px);
    }

    to {
        opacity: 1;
        transform: translateY(0);
    }

    }

    /* Focus visible for accessibility */
    :focus-visible {
        outline: 3px solid var(--primary);
        outline-offset: 2px;
        border-radius: var(--radius-sm);
    }

    /* Loading state for buttons */
    .btn:disabled {
        opacity: 0.7;
        cursor: not-allowed;
        transform: none !important;
    }

    /* Smooth page transition */
    .food-page {
        animation: pageFadeIn 0.5s ease-out;
    }

    @@keyframes pageFadeIn {
        from

    {
        opacity: 0;
        transform: translateY(10px);
    }

    to {
        opacity: 1;
        transform: translateY(0);
    }

    }
    /* ── INPUT GROUP (CUSTOMER SEARCH) ── */
    .input-group {
        position: relative;
        display: flex;
        flex-wrap: nowrap;
        align-items: stretch;
        width: 100%;
        border-radius: var(--radius-sm);
        overflow: hidden;
        transition: all var(--transition);
        background: #fff;
        border: 1px solid #e2e8f0;
    }

        .input-group:focus-within {
            border-color: var(--primary);
            box-shadow: 0 0 0 3px var(--primary-light);
        }

        .input-group .form-control {
            flex: 1 1 auto;
            width: 1%;
            min-width: 0;
            border: none;
            border-radius: 0;
            background: transparent;
            padding: 10px 14px;
            font-size: 0.875rem;
            font-family: "IRANYekan", system-ui, -apple-system, "Segoe UI", Roboto, sans-serif;
        }

            .input-group .form-control:focus {
                outline: none;
                box-shadow: none;
            }

        .input-group .btn-new-customer {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 0 18px;
            background: linear-gradient(135deg, var(--primary), #f97316);
            color: #fff;
            border: none;
            font-size: 0.85rem;
            font-weight: 700;
            font-family: "IRANYekan", system-ui, -apple-system, "Segoe UI", Roboto, sans-serif;
            cursor: pointer;
            white-space: nowrap;
            transition: all var(--transition);
            flex-shrink: 0;
            border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
            margin: -1px -1px -1px 0;
        }

            .input-group .btn-new-customer:hover {
                background: linear-gradient(135deg, #f97316, var(--primary-hover));
                transform: translateX(-2px);
                box-shadow: 0 2px 8px rgba(255, 122, 0, 0.3);
            }

            .input-group .btn-new-customer:active {
                transform: scale(0.97);
            }

            .input-group .btn-new-customer i {
                font-size: 1rem;
            }

        /* RTL support for input-group (since page is rtl) */
        .input-group:not(.has-validation) > :not(:last-child):not(.dropdown-toggle):not(.dropdown-menu),
        .input-group:not(.has-validation) > .dropdown-toggle:nth-last-child(n+3) {
            border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
        }

        .input-group > :not(:first-child):not(.dropdown-menu):not(.valid-tooltip):not(.valid-feedback):not(.invalid-tooltip):not(.invalid-feedback) {
            margin-left: 0;
            border-top-left-radius: var(--radius-sm);
            border-bottom-left-radius: var(--radius-sm);
        }

    /* Responsive adjustments */
    @@media (max-width: 768px) {
        .input-group .btn-new-customer

    {
        padding: 0 14px;
        font-size: 0.75rem;
    }

    .input-group .btn-new-customer i {
        font-size: 0.85rem;
    }

    .input-group .form-control {
        padding: 8px 12px;
        font-size: 0.8rem;
    }

    }

    /* Disabled state */
    .input-group .btn-new-customer:disabled {
        opacity: 0.6;
        cursor: not-allowed;
        transform: none;
    }

    /* Error state */
    .input-group.has-error {
        border-color: #ef4444;
    }

        .input-group.has-error:focus-within {
            box-shadow: 0 0 0 3px rgba(239, 68, 68, 0.2);
        }
</style>


<div class="container food-page mt-4">
    <div class="row">

      
        <div class="col-lg-8">
            

            <div class="food-toolbar mb-3">
                <div class="row g-2 align-items-center">
                    <div class="col-12 col-md-4">
                        <input id="searchBox" type="text" class="form-control form-control-sm" placeholder="جستجو..." />
                    </div>
                    <div class="col-6 col-md-3">
                        <select id="filterCategory" class="form-select form-select-sm">
                            <option value="">همه دسته‌ها</option>
                        </select>
                    </div>
                    <div class="col-6 col-md-2">
                        <select id="filterAvailability" class="form-select form-select-sm">
                            <option value="">همه وضعیت‌ها</option>
                            <option value="true">موجود</option>
                            <option value="false">ناموجود</option>
                        </select>
                    </div>
                    <div class="col-12 col-md-3">
                        <select id="sortBy" class="form-select form-select-sm">
                            <option value="newest">جدیدترین</option>
                            <option value="name-asc">نام (الف تا ی)</option>
                            <option value="name-desc">نام (ی تا الف)</option>
                            <option value="price-asc">قیمت (کم به زیاد)</option>
                            <option value="price-desc">قیمت (زیاد به کم)</option>
                            <option value="discount-desc">بیشترین تخفیف</option>
                        </select>
                    </div>
                </div>
            </div>

            @if (!Model.Any())
            {
                <div class="alert alert-warning text-center">غذایی برای نمایش وجود ندارد.</div>
            }
            else
            {
                <div class="row" id="foodList">
                    @foreach (var item in Model)
                    {
                        var hasDiscount = item.DiscountPrice > 0 && item.DiscountPrice != item.Price;
                        var discountPercent = hasDiscount ? (int)Math.Round(((item.Price - item.DiscountPrice) / item.Price) * 100) : 0;
                        var unavailableClass = item.IsAvailable ? "" : "is-unavailable";
                        <div class="col-6 col-md-4 col-lg-3 mb-3 food-card-item"
                             data-id="@item.FoodItemId"
                             data-name="@item.Name"
                             data-description="@item.Description"
                             data-category="@item.CategoryId"
                             data-categoryname="@item.CategoryName"
                             data-price="@item.Price"
                             data-discountprice="@item.DiscountPrice"
                             data-isavailable="@item.IsAvailable"
                             data-image="@(item.ImageUrl ?? "")">
                            <div class="food-card h-100 @unavailableClass">
                                <div class="food-img-wrap">
                                    <img src="@(string.IsNullOrWhiteSpace(item.ImageUrl) ? placeholder : item.ImageUrl)"
                                         class="food-img" loading="lazy"
                                         onerror="this.onerror=null;this.src='@placeholder';" />
                                    @if (hasDiscount)
                                    {
                                        <span class="ribbon">@discountPercent% تخفیف</span>
                                    }
                                </div>
                                <div class="food-body">
                                    <h5 class="food-title">@item.Name</h5>
                                    <p class="food-desc">@item.Description</p>
                                    <div class="mb-2">
                                        <span class="chip">📂 @item.CategoryName</span>
                                        @if (!item.IsAvailable)
                                        {
                                            <span class="badge bg-danger badge-availability ms-1">ناموجود</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-success badge-availability ms-1">موجود</span>
                                        }
                                    </div>
                                    <div class="price-area">
                                        @if (hasDiscount)
                                        {
                                            <span class="price-old">@item.Price.ToString("N0") تومان</span>
                                            <span class="price-new">@item.DiscountPrice.ToString("N0") تومان</span>
                                        }
                                        else
                                        {
                                            <span class="price-new">@item.Price.ToString("N0") تومان</span>
                                        }
                                    </div>
                                </div>
                                <div class="food-footer">
                                    <button class="btn btn-primary add-to-cart-btn"
                                            data-id="@item.FoodItemId"
                                            data-name="@item.Name"
                                            data-price="@(item.DiscountPrice > 0 ? item.DiscountPrice : item.Price)">
                                         افزودن به سفارش
                                    </button>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>

        <!-- Desktop cart sidebar -->
        <div class="col-lg-4">
            <div class="cart-sidebar">
                <h4 class="cart-title">🛒 سفارش جاری</h4>
                <div id="cart-items-container">
                    <div class="empty-cart">سبد خرید خالی است</div>
                </div>
                <div class="mb-3 mt-3">
                    <label class="form-label">انتخاب میز <span class="text-danger">*</span></label>
                    <select id="tableSelect" class="form-select" required>
                        <option value="">-- انتخاب میز --</option>
                    </select>
                    <small class="text-muted" id="tableSeatsInfo"></small>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold">مشتری </label>
                    <div class="customer-search-wrapper">
                        <div class="input-group">
                            
                            <input type="text" id="desktopCustomerSearch" class="form-control"
                                   placeholder="شماره موبایل یا نام ..." autocomplete="off">
                            <button class="btn btn-new-customer" type="button"
                                    data-bs-toggle="modal" data-bs-target="#newCustomerModal"
                                    data-context="desktop">
                                <i class="bi bi-person-plus"></i> مشتری جدید
                            </button>
                        </div>
                        <div class="search-spinner" id="desktopSearchSpinner"></div>
                        <div id="desktopCustomerSearchResults" class="customer-search-results"></div>
                    </div>
                    <input type="hidden" id="desktopSelectedCustomerId">
                    <div id="desktopSelectedCustomerInfo" class="mt-2"></div>
                </div>
                <div class="mb-3">
                    <label class="form-label">توضیحات</label>
                    <textarea id="orderDescription" class="form-control" rows="2" placeholder="..."></textarea>
                </div>
                <button id="submitOrderBtn" class="btn btn-primary w-100 py-2">نهایی کردن سفارش</button>
            </div>
        </div>
    </div>
</div>

