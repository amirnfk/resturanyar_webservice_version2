<div class="toast-container" id="toastContainer"></div>

<script src="~/js/jquery_3.6.0.min.js"></script>
<script src="~/js/bootstrap.bundle.min.js"></script>
<script>
    // ══════════════════════════════════════════════════════════
    //  CONSTANTS & STATE
    // ══════════════════════════════════════════════════════════
    const API_BASE      = "/api/UserApi";
    const API_CUSTOMERS = "/api/Customers";
    var   restaurantId  = @(ViewBag.RestaurantId ?? 0);

    let cart               = [];
    let selectedCustomerId = null;
    let activeModalContext = 'desktop';
    let isSubmittingOrder  = false;
    let isSubmittingCustomer = false;
    let currentSearchXhr   = null;

    // ══════════════════════════════════════════════════════════
    //  HELPERS
    // ══════════════════════════════════════════════════════════
    function escapeHtml(str) {
        if (!str) return '';
        return String(str).replace(/[&<>"']/g, function(m) {
            return {'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[m];
        });
    }

    function showToast(message, type) {
        type = type || 'success';
        const container = document.getElementById('toastContainer');
        if (!container) return;
        const id    = 'toast-' + Date.now();
        const icons = { success:'✅', error:'❌', info:'ℹ️' };
        const titles = { success:'موفقیت', error:'خطا', info:'اطلاعیه' };
        container.insertAdjacentHTML('beforeend',
            `<div id="${id}" class="toast custom-toast toast-${type}" role="alert" aria-atomic="true" data-bs-autohide="true" data-bs-delay="4000">
                <div class="toast-header"><strong class="me-auto">${icons[type]||''} ${titles[type]||''}</strong>
                <button type="button" class="btn-close btn-close-dark" data-bs-dismiss="toast"></button></div>
                <div class="toast-body">${escapeHtml(message)}</div>
            </div>`);
        const el = document.getElementById(id);
        new bootstrap.Toast(el, { autohide: true, delay: 4000 }).show();
        el.addEventListener('hidden.bs.toast', () => el.remove());
    }

    // ══════════════════════════════════════════════════════════
    //  CUSTOMER HELPERS  (always sync both sides)
    // ══════════════════════════════════════════════════════════
    var CONTEXTS = {
        desktop: {
            searchId:  '#desktopCustomerSearch',
            hiddenId:  '#desktopSelectedCustomerId',
            infoId:    '#desktopSelectedCustomerInfo',
            resultsId: '#desktopCustomerSearchResults',
            spinnerId: '#desktopSearchSpinner'
        },
        offcanvas: {
            searchId:  '#offcanvasCustomerSearch',
            hiddenId:  '#offcanvasSelectedCustomerId',
            infoId:    '#offcanvasSelectedCustomerInfo',
            resultsId: '#offcanvasCustomerSearchResults',
            spinnerId: '#offcanvasSearchSpinner'
        }
    };

    function selectCustomer(id, mobile, name) {
        selectedCustomerId = id;
        const nameHtml = name ? ` - ${escapeHtml(name)}` : '';
        $.each(CONTEXTS, function(ctx, sel) {
            $(sel.hiddenId).val(id);
            $(sel.infoId).html(
                `<div class="selected-customer-card">
                    <div class="customer-detail">
                        <strong>${escapeHtml(mobile)}</strong>${nameHtml}
                        <div class="small text-muted mt-1">✅ انتخاب شده</div>
                    </div>
                    <button type="button" class="btn-change-customer" data-context="${ctx}">تغییر</button>
                </div>`);
            $(sel.searchId).val(mobile + (name ? ' ' + name : ''));
            $(sel.resultsId).empty().hide();
            $(sel.spinnerId).hide();
        });
    }

    function resetCustomer() {
        selectedCustomerId = null;
        $.each(CONTEXTS, function(ctx, sel) {
            $(sel.hiddenId).val('');
            $(sel.infoId).empty();
            $(sel.searchId).val('');
            $(sel.resultsId).empty().hide();
            $(sel.spinnerId).hide();
        });
    }

    function clearCustomerForContext(context) {
        resetCustomer();
        $(CONTEXTS[context].searchId).focus();
    }

    // ══════════════════════════════════════════════════════════
    //  CUSTOMER SEARCH SETUP
    // ══════════════════════════════════════════════════════════
    function setupCustomerSearch(context) {
        var sel = CONTEXTS[context];
        var debounceTimer;

        $(sel.searchId).on('input', function() {
            clearTimeout(debounceTimer);
            var val = $(this).val();
            if (!val.trim()) {
                $(sel.resultsId).empty().hide();
                $(sel.spinnerId).hide();
                return;
            }
            debounceTimer = setTimeout(function() { doSearch(context, val.trim()); }, 400);
        });

        $(document).on('click', sel.resultsId + ' .customer-result-item', function(e) {
            e.preventDefault();
            selectCustomer(
                $(this).data('id'),
                $(this).data('mobile'),
                $(this).data('name') || ''
            );
        });

        // Close results when clicking outside
        $(document).on('click', function(e) {
            if (!$(e.target).closest(sel.searchId).length &&
                !$(e.target).closest(sel.resultsId).length) {
                $(sel.resultsId).hide();



                    




            }
        });
    }

    function doSearch(context, query) {
        var sel = CONTEXTS[context];
        if (currentSearchXhr) currentSearchXhr.abort();
        $(sel.spinnerId).show();
        currentSearchXhr = $.ajax({
            url: API_CUSTOMERS + '/getcustomers/' + restaurantId,
            type: 'GET',
            data: { search: query, page: 1, pageSize: 8 },
            success: function(res) {
                $(sel.spinnerId).hide();
                if (res.success && res.data && res.data.length) {
                    var html = '';
                    res.data.forEach(function(c) {
                        html += `<div class="customer-result-item"
                                      data-id="${c.customerId}"
                                      data-mobile="${escapeHtml(c.mobile)}"
                                      data-name="${escapeHtml(c.fullName || '')}">
                            <div>
                                <div class="customer-mobile">📞 ${escapeHtml(c.mobile)}</div>
                                ${c.fullName ? `<div class="customer-name">${escapeHtml(c.fullName)}</div>` : ''}
                            </div>
                        </div>`;
                    });
                    $(sel.resultsId).html(html).show();
                } else {
                    $(sel.resultsId).html('<div class="p-3 text-center text-muted">مشتری‌ای یافت نشد</div>').show();
                }
            },
            error: function(xhr) {
                if (xhr.statusText === 'abort') return;
                $(sel.spinnerId).hide();
                $(sel.resultsId).html('<div class="p-3 text-center text-danger">خطا در جستجو</div>').show();
            },
            complete: function() { currentSearchXhr = null; }
        });
    }

    // ══════════════════════════════════════════════════════════
    //  NEW CUSTOMER MODAL
    // ══════════════════════════════════════════════════════════
    $('#newCustomerModal').on('show.bs.modal', function(e) {
        var btn = $(e.relatedTarget);
        activeModalContext = btn.data('context') || 'desktop';
        $('#newCustomerMobile, #newCustomerFullName, #newCustomerDesc').val('');
        isSubmittingCustomer = false;
        $('#saveNewCustomerBtn').prop('disabled', false).html('ذخیره و انتخاب');
    });

    $('#newCustomerModal').on('hidden.bs.modal', function() {
       
        $('.modal-backdrop').remove();
        $('body').removeClass('modal-open').css({ overflow: '', paddingRight: '' });
        isSubmittingCustomer = false;
    });

    $('#saveNewCustomerBtn').on('click', function() {
        if (isSubmittingCustomer) return;
        var mobile = $('#newCustomerMobile').val().trim();
        if (!/^09[0-9]{9}$/.test(mobile)) {
            showToast('شماره موبایل معتبر (11 رقم، شروع با 09) وارد کنید', 'error');
            return;
        }
        var fullName    = $('#newCustomerFullName').val().trim();
        if (!fullName) {
            fullName = "مشتری مهمان";  // یا "مشتری " + mobile.substring(0, 4)
            // toastr.info("نام وارد نشده، شماره موبایل به عنوان نام ثبت شد");
        }

        var description = $('#newCustomerDesc').val().trim();
        var $btn = $(this);
        var originalHtml = $btn.html();
        $btn.html('<span class="spinner-border spinner-border-sm me-1"></span> در حال ثبت...').prop('disabled', true);
        isSubmittingCustomer = true;

        $.ajax({
            url: API_CUSTOMERS + '/addcustomer',
            type: 'POST',
            contentType: 'application/json',
            data: JSON.stringify({ restaurantId: restaurantId, mobile: mobile, fullName: fullName, description: description }),
            success: function(res) {
                if (res.success) {
                   showToast('مشتری با موفقیت ثبت شد', 'success');



                     var modalEl = document.getElementById('newCustomerModal');
                var bsModal = bootstrap.Modal.getInstance(modalEl);
                if (bsModal) bsModal.hide();

                // Manually remove any lingering backdrops
                setTimeout(function() {
                    $('.modal-backdrop').remove();
                    $('body').removeClass('modal-open');
                    $('body').css({ overflow: '', paddingRight: '' });
                }, 150);











         

                    selectCustomer(res.customerId, mobile, fullName);






                    





                } else {
                    showToast(res.message || 'خطا در ثبت مشتری', 'error');
                    $btn.html(originalHtml).prop('disabled', false);
                    isSubmittingCustomer = false;
                }
            },
            error: function(xhr) {
                var msg = 'خطا در ارتباط با سرور';
                if (xhr.responseJSON && xhr.responseJSON.message) msg = xhr.responseJSON.message;
                showToast(msg, 'error');
                $btn.html(originalHtml).prop('disabled', false);
                isSubmittingCustomer = false;
            }
        });
    });

    $(document).on('click', '.btn-change-customer', function() {
        clearCustomerForContext($(this).data('context'));
    });

    // ══════════════════════════════════════════════════════════
    //  CART
    // ══════════════════════════════════════════════════════════
    function renderCart() {
        var itemCount  = cart.reduce(function(s,i){ return s + i.quantity; }, 0);
        var cartTotal  = cart.reduce(function(s,i){ return s + i.price * i.quantity; }, 0);

        function buildHtml(container) {
            if (!$(container).length) return;
            if (!cart.length) {
                $(container).html('<div class="empty-cart">سبد خرید خالی است</div>');
                return;
            }
            var html = '<div class="cart-items-list">';
            cart.forEach(function(item, idx) {
                var itemTotal = item.price * item.quantity;
                html += `<div class="cart-item">
                    <div class="cart-item-info">
                        <strong>${escapeHtml(item.name)}</strong>
                        <small>${item.price.toLocaleString()} تومان</small>
                    </div>
                    <div class="cart-item-actions">
                        <input type="number" min="1" value="${item.quantity}" class="cart-qty" data-idx="${idx}">
                        <button class="remove-item-btn" data-idx="${idx}">🗑️</button>
                    </div>
                    <div class="cart-item-total ms-2 fw-bold">${itemTotal.toLocaleString()} تومان</div>
                </div>`;
            });
            html += `<div class="cart-total d-flex justify-content-between">
                        <span>جمع کل:</span>
                        <span>${cartTotal.toLocaleString()} تومان</span>
                     </div>`;
            $(container).html(html);
        }

        buildHtml('#cart-items-container');
        buildHtml('#offcanvas-cart-items-container');
        $('#mobileCartCount').text(itemCount);
        $('#mobileCartTotal').text(cartTotal.toLocaleString());
    }

    function addToCart(id, name, price) {
        var existing = cart.find(function(i){ return i.id === id; });
        if (existing) existing.quantity++;
        else cart.push({ id: id, name: name, price: price, quantity: 1 });
        renderCart();
    }

    $(document).on('click', '.add-to-cart-btn', function() {
        addToCart(parseInt($(this).data('id')), $(this).data('name'), parseFloat($(this).data('price')));
    });
    $(document).on('change', '.cart-qty', function() {
        var idx = parseInt($(this).data('idx'));
        var val = parseInt($(this).val());
        if (isNaN(val) || val < 1) cart.splice(idx, 1);
        else cart[idx].quantity = val;
        renderCart();
    });
    $(document).on('click', '.remove-item-btn', function() {
        cart.splice(parseInt($(this).data('idx')), 1);
        renderCart();
    });

    // ══════════════════════════════════════════════════════════
    //  TABLES
    // ══════════════════════════════════════════════════════════
    function loadTables() {
        if (!restaurantId) return;
        $.ajax({
            url: API_BASE + '/gettablesbyrestaurant/' + restaurantId,
            type: 'GET',
            success: function(data) {
                var base = '<option value="">-- انتخاب میز --</option>';
                if (data.tables && data.tables.length) {
                    var opts = '';
                    data.tables.forEach(function(t) {
                        opts += `<option value="${escapeHtml(t.tableName)}" data-seats="${t.seats}">
                                    ${escapeHtml(t.tableName)} (${t.seats} صندلی)
                                 </option>`;
                    });
                    $('#tableSelect, #offcanvasTableSelect').html(base + opts);
                } else {
                    $('#tableSelect, #offcanvasTableSelect').html(base + '<option disabled>میز فعالی یافت نشد</option>');
                }
            },
            error: function() {
                $('#tableSelect, #offcanvasTableSelect').html('<option value="">-- خطا در بارگذاری میزها --</option>');
                showToast('خطا در دریافت لیست میزها', 'error');
            }
        });
    }

    $(document).on('change', '#tableSelect', function() {
        var seats = $(this).find(':selected').data('seats');
        $('#tableSeatsInfo').text(seats ? 'تعداد صندلی‌ها: ' + seats : '');
    });
    $(document).on('change', '#offcanvasTableSelect', function() {
        var seats = $(this).find(':selected').data('seats');
        $('#offcanvasTableSeatsInfo').text(seats ? 'تعداد صندلی‌ها: ' + seats : '');
    });

    // ══════════════════════════════════════════════════════════
    //  SUBMIT ORDER
    // ══════════════════════════════════════════════════════════
    function submitOrder(tableSelectId, descriptionId, btnElement) {
        if (isSubmittingOrder) return;

        var tableName = $(tableSelectId).val();
        if (!tableName) {
            showToast('لطفاً یک میز را انتخاب کنید.', 'error');
            return;
        }
        if (!cart.length) {
            showToast('هیچ آیتمی به سفارش اضافه نشده است.', 'error');
            return;
        }

        isSubmittingOrder = true;
        var $btn = $(btnElement);
        var originalHtml = $btn.html();
        $btn.html('<span class="spinner-border spinner-border-sm me-1"></span> در حال ثبت...').prop('disabled', true);

        $.ajax({
            url: API_BASE + '/createOrder',
            type: 'POST',
            contentType: 'application/json',
            data: JSON.stringify({
                restaurantId: restaurantId,
                tableNumber:  tableName,
                statusId:     3,
                description:  $(descriptionId).val().trim(),
                items:        cart.map(function(i){ return { foodItemId: i.id, quantity: i.quantity }; }),
                customerId:   selectedCustomerId
            }),
            success: function(res) {
                if (res.success) {
                    showToast('سفارش با موفقیت ثبت شد!', 'success');
                    cart = [];
                    resetCustomer();
                    renderCart();
                    $('#tableSelect, #offcanvasTableSelect').val('');
                    $('#tableSeatsInfo, #offcanvasTableSeatsInfo').text('');
                    $('#orderDescription, #offcanvasOrderDescription').val('');
                    var oc = bootstrap.Offcanvas.getInstance(document.getElementById('cartOffcanvas'));
                    if (oc) oc.hide();
                } else {
                    showToast('خطا در ثبت سفارش: ' + (res.message || 'نامشخص'), 'error');
                }
            },
            error: function(xhr) {
                var msg = 'خطای ارتباط با سرور';
                if (xhr.status === 401) msg = 'لطفاً ابتدا وارد حساب کاربری خود شوید.';
                else if (xhr.responseJSON && xhr.responseJSON.message) msg = xhr.responseJSON.message;
                showToast(msg, 'error');
            },
            complete: function() {
                isSubmittingOrder = false;
                $btn.html(originalHtml).prop('disabled', false);
            }
        });
    }

    $('#submitOrderBtn').on('click', function() { submitOrder('#tableSelect', '#orderDescription', this); });
    $('#offcanvasSubmitOrderBtn').on('click', function() { submitOrder('#offcanvasTableSelect', '#offcanvasOrderDescription', this); });


    function populateFilterCategories() {
        $.ajax({
            url: API_BASE + '/getcategoriesbyrestaurant/' + restaurantId,
            type: 'GET',
            success: function(data) {
                var $sel = $('#filterCategory').empty().append('<option value="">همه دسته‌ها</option>');
                (data.categories || []).forEach(function(c) {
                    $sel.append(`<option value="${c.categoryId}">${escapeHtml(c.categoryName)}</option>`);
                });
            },
            error: function() {
                var seen = new Set();
                $('.food-card-item').each(function() {
                    var id = String($(this).data('category'));
                    var name = $(this).data('categoryname');
                    if (id && !seen.has(id)) {
                        $('#filterCategory').append(`<option value="${id}">${escapeHtml(name)}</option>`);
                        seen.add(id);
                    }
                });
            }
        });
    }

    function applyFilters() {
        var q    = $('#searchBox').val().trim().toLowerCase();
        var cat  = $('#filterCategory').val();
        var avail = $('#filterAvailability').val();
        var sort = $('#sortBy').val();

        var cards = $('.food-card-item').toArray();
        cards.forEach(function(el) {
            var $el = $(el);
            var name     = ($el.data('name') || '').toString().toLowerCase();
            var desc     = ($el.data('description') || '').toString().toLowerCase();
            var category = String($el.data('category') || '');
            var isAvail  = String($el.data('isavailable')).toLowerCase();
            var ok = true;
            if (q    && !(name.includes(q) || desc.includes(q))) ok = false;
            if (cat  && category !== String(cat))                ok = false;
            if (avail && isAvail !== String(avail))              ok = false;
            $el.toggle(ok);
        });

        var visible = $('.food-card-item:visible').toArray();
        visible.sort(function(a, b) {
            var $a = $(a), $b = $(b);
            var nameA = ($a.data('name') || '').toString();
            var nameB = ($b.data('name') || '').toString();
            var priceA = parseFloat($a.data('price') || 0);
            var priceB = parseFloat($b.data('price') || 0);
            var discA  = parseFloat($a.data('discountprice') || 0);
            var discB  = parseFloat($b.data('discountprice') || 0);
            var finalA = discA > 0 ? discA : priceA;
            var finalB = discB > 0 ? discB : priceB;
            switch (sort) {
                case 'name-asc':      return nameA.localeCompare(nameB, 'fa');
                case 'name-desc':     return nameB.localeCompare(nameA, 'fa');
                case 'price-asc':     return finalA - finalB;
                case 'price-desc':    return finalB - finalA;
                case 'discount-desc': return (priceA - discA) - (priceB - discB);
                default:              return 0;
            }
        });
        var $container = $('#foodList');
        visible.forEach(function(el) { $container.append(el); });
    }

    // ══════════════════════════════════════════════════════════
    //  INIT
    // ══════════════════════════════════════════════════════════
    $(function() {
        populateFilterCategories();
        loadTables();
        renderCart();
        $('#searchBox, #filterCategory, #filterAvailability, #sortBy').on('input change', applyFilters);
        setupCustomerSearch('desktop');
        setupCustomerSearch('offcanvas');
    });
</script>