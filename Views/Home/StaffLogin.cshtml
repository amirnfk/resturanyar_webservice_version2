@model resturanyar.Models.LoginUserRequest

<!DOCTYPE html>
<html lang="fa" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>ورود کارمند</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.rtl.min.css" rel="stylesheet" />
    <link href="~/css/site.css" rel="stylesheet" />
    <style>
        body {
            background-color: #ffffff;
        }

        .main-box {
            max-width: 420px;
            margin: -180px auto 0 auto;
        }

        .logo-img {
            width: 90px;
            height: 90px;
            margin: 0 auto;
        }

        .bg-orange {
            background-color: #FF8800;
        }

        .text-orange {
            color: #FF8800;
        }

        .btn-orange {
            background-color: #FF8800;
            color: #fff;
        }

            .btn-orange:hover {
                background-color: #e06e00;
            }

        .form-label {
            font-weight: 500;
        }

        .form-control::placeholder {
            color: #ccc;
            font-size: 0.9rem;
        }
    </style>
</head>
<body class="bg-white">
    <div class="bg-orange" style="height:220px;"></div>
    <div class="main-box text-center position-relative">
        <img src="~/images/logo.png" alt="لوگو" class="rounded-circle  shadow logo-img" />
        <div class="card mt-4 shadow rounded-4">
            <div class="card-body px-4 py-5 text-start">
                <h5 class="text-orange fw-bold text-center mb-4">ورود کارمند</h5>

                @if (ViewBag.RoleMessage != null)
                {
                    <div class="alert alert-warning text-center mt-4">
                        @ViewBag.RoleMessage
                    </div>
                }

                @if (ViewBag.Error != null)
                {
                    <div class="alert alert-danger mt-4 text-center">@ViewBag.Error</div>
                }

                <form asp-action="StaffLogin" method="post">
                    <div class="mb-3">
                        <label asp-for="restaurant_code" class="form-label">کد رستوران</label>
                        <input asp-for="restaurant_code" class="form-control form-control-lg text-end" placeholder="مثلاً 123ABC" />
                        <span asp-validation-for="restaurant_code" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="name" class="form-label">نام کاربری</label>
                        <input asp-for="name" class="form-control form-control-lg text-end" placeholder="مثلاً ali123" />
                        <span asp-validation-for="name" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="password" class="form-label">رمز عبور</label>
                        <input asp-for="password" type="password" class="form-control form-control-lg text-end" placeholder="رمز عبور" />
                        <span asp-validation-for="password" class="text-danger small"></span>
                    </div>
                    <div class="d-grid mt-4">
                        <button type="submit" class="btn btn-orange btn-lg fw-bold">ورود</button>
                    </div>
                </form>
            </div>
        </div>
        <img src="~/images/bergerback.jpg" alt="تصویر پس‌زمینه" class="img-fluid mt-4" style="max-height: 240px; object-fit: contain;" />
    </div>
</body>
</html>
