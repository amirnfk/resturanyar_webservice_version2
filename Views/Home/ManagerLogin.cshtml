@model resturanyar.Models.OwnerLoginRequest
<!DOCTYPE html>
<html lang="fa" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>ورود مدیر رستوران</title>
    <link href="~/css/bootstrap_rtl_min.css" rel="stylesheet">
    <link href="~/css/site.css" rel="stylesheet" />
    
    <script src="~/js/sweetalert2@11.js"></script>
    <link href="~/css/managerlogin.css" rel="stylesheet" asp-append-version="true" />
</head>
<body class="bg-white">
   
    <div class="bg-orange" style="height:220px;"></div>
     
    <div class="main-box text-center position-relative">
      
        <img src="~/images/logo.png" alt="لوگو" class="rounded-circle shadow logo-img" />
        
        <div class="card mt-4 shadow rounded-4">
            <div class="card-body px-4 py-5 text-start">
                <h5 class="text-orange fw-bold text-center mb-4">ورود مدیر رستوران</h5>

              
                <div id="login-password-section">
                    <form asp-action="ManagerLogin" method="post" id="passwordForm">
                        <div class="mb-3">
                            <label asp-for="Phone" class="form-label">شماره تلفن</label>
                            <input asp-for="Phone" class="form-control form-control-lg text-end" placeholder="مثلاً 09121234567" />
                            <span asp-validation-for="Phone" class="text-danger"></span>
                        </div>
                        <div class="mb-3">
                            <label asp-for="Password" class="form-label">رمز عبور</label>
                            <input asp-for="Password" type="password" class="form-control form-control-lg text-end" placeholder="رمز عبور" />
                            <span asp-validation-for="Password" class="text-danger"></span>
                        </div>
                        <div class="d-grid mt-4">
                            <button type="submit" class="btn btn-orange btn-lg fw-bold">ورود</button>
                        </div>
                        @if (ViewBag.Error != null)
                        {
                            <div class="alert alert-danger mt-3 text-center">@ViewBag.Error</div>
                        }
                    </form>

                   
                    <div class="text-center mt-3">
                        <button type="button" id="btnSwitchToOtp" class="btn-modern-switch">
                          
                            
                            ورود با کد یکبار مصرف  
                        </button>
                       
                    </div>
                    <div class="text-center mt-3">
                        <button type="button" id="btnSwitchToRegister" class="btn-modern-switch">


                           ثبت نام
                        </button>

                    </div>
                </div>

               
                <div id="login-otp-section" class="d-none">

                  
                    <div id="otp-step-phone">
                        <div class="mb-3">
                            <label class="form-label">شماره تلفن</label>
                            <input id="otpPhoneInput" class="form-control form-control-lg text-end" placeholder="مثلاً 09121234567" />
                            <span id="otpPhoneError" class="text-danger small"></span>
                        </div>
                        <div class="d-grid mt-4">
                            <button id="btnGetOtp" class="btn btn-orange btn-lg fw-bold w-100">دریافت کد تایید</button>
                        </div>
                    </div>

                    
                    <div id="otp-step-code" class="d-none">
                        <div class="alert alert-info text-center small">
                            کد تایید برای شماره <span id="displayPhone" class="fw-bold"></span> ارسال شد.
                        </div>
                        <div class="mb-3">
                            <label class="form-label">کد تایید</label>
                            <input id="otpCodeInput" type="text" class="form-control form-control-lg text-center" placeholder="کد ۴ رقمی" maxlength="4" />
                            <span id="otpCodeError" class="text-danger small"></span>
                        </div>
                        <div class="d-grid mt-4">
                            <button id="btnVerifyOtp" class="btn btn-orange btn-lg fw-bold">تایید و ورود</button>
                        </div>
                        <div class="text-center mt-3">
                            <button id="btnEditPhone" class="btn-edit-phone">
                                ویرایش شماره
                            </button>
                        </div>
                    </div>

                   
                    <div class="text-center mt-4 pt-3 border-top">
                        <button type="button" id="btnSwitchToPassword" class="btn-link-custom">
                            ورود با رمز عبور
                        </button>
                    </div>
                </div>

            </div>
        </div>
       
        <img src="~/images/bergerback.jpg" alt="پس‌زمینه" class="img-fluid mt-4" style="max-height: 240px; object-fit: contain;" />
    </div>

    <!-- مودال ثبت‌نام -->
    <div class="modal fade" id="registerModal" tabindex="-1" data-bs-backdrop="static">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content rounded-4">
                <div class="modal-header border-0 pb-0">
                    <h5 class="modal-title text-orange fw-bold w-100 text-center">تکمیل اطلاعات ثبت‌نام</h5>
                </div>
                <div class="modal-body px-4">
                    <p class="text-muted text-center small mb-4">شماره شما تایید شد. لطفاً اطلاعات زیر را تکمیل کنید.</p>

                    <div class="mb-3">
                        <label class="form-label">نام و نام خانوادگی</label>
                        <input id="registerName" type="text" class="form-control form-control-lg text-end" placeholder="نام کامل" />
                        <div id="registerNameError" class="invalid-feedback"></div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">رمز عبور</label>
                        <input id="registerPassword" type="password" class="form-control form-control-lg text-end" placeholder="رمز عبور (حداقل ۶ کاراکتر)" />
                        <div id="registerPasswordError" class="invalid-feedback"></div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">تکرار رمز عبور</label>
                        <input id="registerConfirmPassword" type="password" class="form-control form-control-lg text-end" placeholder="دوباره رمز عبور را وارد کنید" />
                        <div id="registerConfirmError" class="invalid-feedback"></div>
                    </div>

                    <div class="d-grid mt-4 mb-2">
                        <button id="btnRegisterSubmit" class="btn btn-orange btn-lg fw-bold">ثبت‌نام و ورود</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <script src="~/js/managerlogin.js" asp-append-version="true"></script>
</body>
</html>